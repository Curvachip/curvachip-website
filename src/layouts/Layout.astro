		label: "X / Twitter",
		href: "https://x.com/curvachip",
		abbr: `𝕏`,
	},
	{
		label: "Instagram",
		href: "https://www.instagram.com/curvachip/",
		abbr: `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
	},
	{
		label: "YouTube",
		href: "https://www.youtube.com/@curvachip",
		abbr: `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
	},
	{
		label: "TikTok",
		href: "https://www.tiktok.com/@curvachip",
		abbr: `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.87a8.18 8.18 0 004.78 1.52V7a4.85 4.85 0 01-1.01-.31z"/></svg>`,
	},
	{
		label: "App Store",
		href: "https://apps.apple.com/fi/developer/curvachip-llc/id1774903560",
		abbr: ``,
	},
	{
		label: "Spotify",
		href: "https://open.spotify.com/user/31dvsb5yckqhavs7rhxm7ow6g7ny",
		abbr: `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>`,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary meta -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Curvachip" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalUrl} />

		<!-- Favicon -->
		<!-- ─────────────────────────────────────────────────────────
       Place your favicon files in src/public/ and update the
       paths below. Recommended set:
         /favicon.ico          (32×32, legacy browsers)
         /favicon.svg          (modern browsers — scales perfectly)
         /apple-touch-icon.png (180×180, iOS home screen)
         /site.webmanifest     (PWA manifest for Android)
       ───────────────────────────────────────────────────────── -->
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#5B9CF6" />

		<!-- Fonts -->
		<!-- Self-hosted via @fontsource packages bundled with the site -->

		<!-- Allow pages to inject extra <head> content (e.g. page-specific meta) -->
		<slot name="head" />
	</head>
	<body>
		<!-- ══════════════════════════════════════════════════════════
     NAV
     Edit navItems at the top of this file to add/remove links.
     ══════════════════════════════════════════════════════════ -->
		<nav class="nav">
			<div class="nav-inner">
				<!-- Logo -->
				<a href="/" class="nav-logo" aria-label="Curvachip home">
					<img
						src="/graphiclogodark.svg"
						alt="Curvachip logo"
						class="logo-chip"
						loading="eager"
					/>
					<span class="logo-text">Curvachip</span>
				</a>

				<!-- Desktop links -->
				<ul class="nav-links" id="nav-links" role="list">
					{
						navItems.map((item) => (
							<li>
								<a
									href={item.href}
									class={`nav-link${activeNav === item.key ? " active" : ""}`}
									aria-current={
										activeNav === item.key
											? "page"
											: undefined
									}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>

				<!-- Hamburger (mobile only) -->
				<button
					class="hamburger"
					id="hamburger"
					aria-label="Open menu"
					aria-expanded="false"
					aria-controls="nav-links"
				>
					<span class="ham-bar"></span>
					<span class="ham-bar"></span>
					<span class="ham-bar"></span>
				</button>
			</div>

			<!-- Mobile drawer (overlay, does not push content) -->
			<div
				class="mobile-menu"
				id="mobile-menu"
				aria-hidden="true"
				role="dialog"
				aria-label="Navigation menu"
			>
				<ul class="mobile-links" role="list">
					{
						navItems.map((item) => (
							<li>
								<a
									href={item.href}
									class={`mobile-link${activeNav === item.key ? " mobile-link--active" : ""}`}
									aria-current={
										activeNav === item.key
											? "page"
											: undefined
									}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</nav>

		<!-- ══════════════════════════════════════════════════════════
     PAGE CONTENT
     Each page's markup is slotted in here.
     ══════════════════════════════════════════════════════════ -->
		<slot />

		<!-- ══════════════════════════════════════════════════════════
     FOOTER
     Edit socials / links at the top of this file.
     ══════════════════════════════════════════════════════════ -->
		<footer class="footer">
			<div class="container footer-inner">
				<div class="footer-brand">
					<img
						src="/graphiclogodark.svg"
						alt="Curvachip logo"
						class="logo-chip"
						loading="lazy"
					/>
					<span class="logo-text">Curvachip</span>
					<p class="footer-tagline">
						Crafting exceptional software for Apple platforms.
					</p>
				</div>

				<nav class="footer-nav" aria-label="Footer navigation">
					{
						navItems.map((item) => (
							<a href={item.href} class="footer-link">
								{item.label}
							</a>
						))
					}
				</nav>

				<div class="footer-social">
					{
						socials.map((s) => (
							<a
								href={s.href}
								class="social-link"
								target={
									s.href.startsWith("mailto")
										? "_self"
										: "_blank"
								}
								rel={
									s.href.startsWith("mailto")
										? undefined
										: "noopener noreferrer"
								}
								aria-label={s.label}
							>
								<Fragment set:html={s.abbr} />
							</a>
						))
					}
				</div>

				<p class="footer-legal">
					Copyright &copy; {new Date().getFullYear()} Curvachip LLC. All
					rights reserved.<br />
					<small
						>Apple is a trademark of Apple Inc. and is not
						affiliated with Curvachip LLC.</small
					>
				</p>

				<div class="footer-policy-links">
					<a href="/privacy/website" class="footer-link"
						>Privacy Policy</a
					>
					<span aria-hidden="true">&middot;</span>
					<a href="/privacy/terms-of-use" class="footer-link"
						>Terms of Use</a
					>
				</div>
			</div>
		</footer>

		<!-- ══════════════════════════════════════════════════════════
     HAMBURGER SCRIPT
     Defined once here — works on every page automatically.
     ══════════════════════════════════════════════════════════ -->
		<script>
			const hamburger = document.getElementById(
				"hamburger",
			) as HTMLButtonElement | null;
			const mobileMenu = document.getElementById(
				"mobile-menu",
			) as HTMLElement | null;

			if (hamburger && mobileMenu) {
				// Toggle open / closed
				hamburger.addEventListener("click", () => {
					const open =
						mobileMenu.classList.toggle("mobile-menu--open");
					hamburger.setAttribute("aria-expanded", String(open));
					mobileMenu.setAttribute("aria-hidden", String(!open));
					hamburger.classList.toggle("hamburger--open", open);
					// Prevent body scroll while menu is open
					document.body.style.overflow = open ? "hidden" : "";
				});

				// Close on Escape key
				document.addEventListener("keydown", (e) => {
					if (
						e.key === "Escape" &&
						mobileMenu.classList.contains("mobile-menu--open")
					) {
						mobileMenu.classList.remove("mobile-menu--open");
						mobileMenu.setAttribute("aria-hidden", "true");
						hamburger.setAttribute("aria-expanded", "false");
						hamburger.classList.remove("hamburger--open");
						document.body.style.overflow = "";
						hamburger.focus();
					}
				});

				// Close when a mobile link is tapped (navigating to current page)
				mobileMenu.querySelectorAll(".mobile-link").forEach((link) => {
					link.addEventListener("click", () => {
						mobileMenu.classList.remove("mobile-menu--open");
						mobileMenu.setAttribute("aria-hidden", "true");
						hamburger.setAttribute("aria-expanded", "false");
						hamburger.classList.remove("hamburger--open");
						document.body.style.overflow = "";
					});
				});
			}
		</script>
	</body>
</html>

<!-- ══════════════════════════════════════════════════════════
     GLOBAL STYLES
     Defined once here — inherited by every page.
     ══════════════════════════════════════════════════════════ -->
<style is:global>
	/* ── DESIGN TOKENS ─────────────────────────────────────── */
	/* Change a value here and it updates across every page.   */
	:root {
		/* Palette */
		--cc-bg: #080810;
		--cc-surface: #10101e;
		--cc-border: #1c1c32;
		--cc-blue: #5b9cf6;
		--cc-blue-dim: rgba(91, 156, 246, 0.12);
		--cc-violet: #a78bfa;
		--cc-green: #34d399;
		--cc-amber: #fbbf24;
		--cc-red: #ef4444;
		--cc-text: #e8e8f0;
		--cc-muted: #6a6a88;
		--cc-radius: 12px;
		--cc-max: 1120px;

		/* Typography */
		--font-display: "Outfit", system-ui, sans-serif;
		--font-body: "Inter", system-ui, sans-serif;
		--font-size-base: 1.0625rem; /* 17px */
	}

	::selection {
		background: rgba(91, 156, 246, 0.2);
		color: var(--cc-text);
	}

	::-moz-selection {
		background: rgba(91, 156, 246, 0.2);
		color: var(--cc-text);
	}

	/* ── RESET ─────────────────────────────────────────────── */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
	html {
		scroll-behavior: smooth;
	}
	:target {
		scroll-margin-top: 80px;
	}
	body {
		background: var(--cc-bg);
		color: var(--cc-text);
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		line-height: 1.65;
		-webkit-font-smoothing: antialiased;
	}
	a {
		color: inherit;
		text-decoration: none;
	}
	strong {
		font-weight: 600;
	}
	em {
		font-style: normal;
	}

	/* ── LAYOUT ─────────────────────────────────────────────── */
	.container {
		width: 100%;
		max-width: var(--cc-max);
		margin-inline: auto;
		padding-inline: clamp(1.25rem, 5vw, 2.5rem);
	}

	/* ── NAV ─────────────────────────────────────────────────── */
	.nav {
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid var(--cc-border);
	}
	.nav::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -1;
		background: rgba(8, 8, 16, 0.8);
		-webkit-backdrop-filter: blur(16px);
		backdrop-filter: blur(16px);
	}
	.nav-inner {
		max-width: var(--cc-max);
		margin-inline: auto;
		padding-inline: clamp(1.25rem, 5vw, 2.5rem);
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		font-size: 1.05rem;
		letter-spacing: -0.01em;
	}
	.logo-text {
		font-weight: 600;
	}
	.logo-chip {
		height: 28px;
		width: auto;
		display: block;
	}
	.nav-links {
		display: flex;
		gap: 0.25rem;
		list-style: none;
	}
	.nav-link {
		padding: 0.35rem 0.75rem;
		border-radius: 6px;
		font-size: 0.875rem;
		color: var(--cc-muted);
		transition:
			color 0.15s,
			background 0.15s;
	}
	.nav-link:hover,
	.nav-link.active {
		color: var(--cc-text);
		background: rgba(255, 255, 255, 0.06);
	}

	/* ── HAMBURGER ───────────────────────────────────────────── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 6px;
		border-radius: 6px;
	}
	.hamburger:focus-visible {
		outline: 2px solid var(--cc-blue);
		outline-offset: 2px;
	}
	.ham-bar {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--cc-text);
		border-radius: 2px;
		transition:
			transform 0.22s ease,
			opacity 0.18s ease;
		transform-origin: center;
	}
	.hamburger--open .ham-bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.hamburger--open .ham-bar:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.hamburger--open .ham-bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	@media (max-width: 640px) {
		.nav-links {
			display: none;
		}
		.hamburger {
			display: flex;
		}
	}

	/* ── MOBILE MENU ─────────────────────────────────────────── */
	.mobile-menu {
		display: none;
		position: fixed;
		top: 60px;
		left: 0;
		right: 0; /* overlay, never pushes content */
		border-top: 1px solid var(--cc-border);
		background: rgba(8, 8, 16, 0.97);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		z-index: 99;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
	}
	.mobile-menu--open {
		display: block;
	}
	.mobile-links {
		list-style: none;
		padding: 0.75rem clamp(1.25rem, 5vw, 2.5rem);
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.mobile-link {
		display: block;
		padding: 0.7rem 0.75rem;
		border-radius: 8px;
		font-size: 1rem;
		color: var(--cc-muted);
		transition:
			color 0.15s,
			background 0.15s;
