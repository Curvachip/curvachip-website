  <!-- ── VALUES ──────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What we stand for</h2>
      <div class="values-grid">
        {
          values.map((v) => (
            <div class="value-card">
              <span class="value-icon" aria-hidden="true">
                {v.icon}
              </span>
              <h3 class="value-label">{v.label}</h3>
              <p class="value-body">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── FEATURED APPS ───────────────────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Featured apps</h2>
      <p class="section-sub">
        Every app is built for a purpose — vetted, designed, and submitted to
        the App Store with intention.
      </p>
      <div class="apps-grid">
        {
          apps.map((app) => (
            <a href={app.href} class="app-card">
              <span class="app-emoji" aria-hidden="true">
                <img src={app.iconUrl} alt={app.name} width="45" height="45" />
              </span>
              <div>
                <p class="app-tagline">{app.tagline}</p>
                <h3 class="app-name">{app.name}</h3>
                <p class="app-blurb">{app.blurb}</p>
              </div>
              <span class="app-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
      <div class="cta-row">
        <a href="/apps" class="btn btn-primary">See all apps</a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIAL ─────────────────────────────────────────── -->
  <section class="section">
    <div class="container testimonial-wrap">
      <blockquote class="testimonial">
        <p class="testimonial-quote">
          "We all enjoyed and appreciated Michael's preparation, his earnest
          interest in listening, and his thoughtful dialogue … he is ready to
          GO!"
        </p>
        <footer class="testimonial-footer">
          <cite>
            Cathy Hayes — <a
              href="https://www.hayesstudio.com/home"
              target="_blank"
              rel="noopener">Hayes Inc.</a
            >
          </cite>
        </footer>
      </blockquote>
    </div>
  </section>


</Layout>

