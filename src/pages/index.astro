---
// src/pages/index.astro
// HOME PAGE
// ─────────────────────────────────────────────────────────────
// If you have a Layout component, replace the raw <html> shell
// below with: import Layout from '../layouts/Layout.astro'
// and wrap the body content in <Layout title="..." description="...">.
// ─────────────────────────────────────────────────────────────

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

const title = "Software Development for Apple Platforms | Curvachip";
const description =
  "Curvachip LLC crafts exceptional, privacy-first software for Apple platforms. Built by an indie developer who believes great apps should be secure, beautiful, and honest.";

const apps = [
  {
    name: "Shadow Task",
    tagline: "Focus & Track",
    blurb:
      "A Pomodoro timer with identifiable tasks, progress tracking, and personal quote prompts — all stored entirely on-device.",
    href: "/shadow-task",
    iconUrl: "shadow-task.png",
  },
  {
    name: "TipZap",
    tagline: "Tip Calculator",
    blurb:
      "Split dinner costs, round totals, and calculate tips in seconds. The number pad is built right in.",
    href: "/tipzap",
    iconUrl: "tipzap.png",
  },
  {
    name: "StoneClip",
    tagline: "Rock Identifier",
    blurb:
      "Point your camera at any rock and get an AI-powered identification with full geological context, instantly.",
    href: "/stoneclip-rock-identifier",
    iconUrl: "stoneclip.png",
  },
];

const values = [
  {
    label: "User-Focused Design",
    body: "Every decision — layout, color, copy — is made with a single question in mind: does this make it easier for the user?",
    icon: "◎",
  },
  {
    label: "Privacy by Default",
    body: "On-device processing wherever possible. No silent collection. What stays on your device stays on your device.",
    icon: "◈",
  },
  {
    label: "Feedback-Driven",
    body: "Criticism is a gift. Every App Store review, every email, every bug report shapes the next update.",
    icon: "◬",
  },
];
---

<Layout
  title={title}
  description={description}
  activeNav="home"
  canonicalUrl="https://curvachip.com/"
>
