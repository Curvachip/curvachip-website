<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ─────────────────────────────────────────────────────────
     All custom properties are defined on :root so any nested
     page or component can reference them. If you move content
     into a layout component, move the :root block there too.
     ═══════════════════════════════════════════════════════════ -->

<style>
  /* ── HERO ── */
  
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── SECTIONS ── */
  .section {
    padding: clamp(4rem, 9vw, 7rem) 0;
  }
  .section-alt {
    background: var(--cc-surface);
  }
  .section-title {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }
  .section-sub {
    color: var(--cc-muted);
    max-width: 520px;
    margin-bottom: 3rem;
    font-size: 1rem;
  }

  /* ── VALUES ── */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .value-card {
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 2rem 1.75rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }
  .value-card:hover {
    border-color: rgba(91, 156, 246, 0.4);
    box-shadow: 0 0 24px rgba(91, 156, 246, 0.07);
  }
  .value-icon {
    display: block;
    font-size: 1.5rem;
    color: var(--cc-blue);
    margin-bottom: 1rem;
    line-height: 1;
  }
  .value-label {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  .value-body {
    color: var(--cc-muted);
    font-size: 0.9rem;
  }

  /* ── APPS GRID ── */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .app-card {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 1rem;
    align-items: start;
    background: var(--cc-bg);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 1.5rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    cursor: pointer;
  }
  .app-card:hover {
    border-color: rgba(91, 156, 246, 0.4);
    box-shadow: 0 0 20px rgba(91, 156, 246, 0.08);
  }
  .app-emoji {
    font-size: 1.75rem;
    line-height: 1;
    margin-top: 0.15rem;
  }
  .app-tagline {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cc-blue);
    margin-bottom: 0.2rem;
  }
  .app-name {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .app-blurb {
    color: var(--cc-muted);
    font-size: 0.85rem;
  }
  .app-arrow {
    color: var(--cc-muted);
    margin-top: 0.25rem;
    transition:
      color 0.15s,
      transform 0.15s;
  }
  .app-card:hover .app-arrow {
    color: var(--cc-blue);
    transform: translateX(3px);
  }

  .cta-row {
    text-align: center;
  }

  /* ── TESTIMONIAL ── */
  .testimonial-wrap {
    max-width: 700px;
  }
  .testimonial {
    border-left: 3px solid var(--cc-blue);
    padding-left: 2rem;
  }
  .testimonial-quote {
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    font-style: italic;
    color: var(--cc-text);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .testimonial-footer cite {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--cc-muted);
  }
  .testimonial-footer a {
    color: var(--cc-blue);
  }
</style>
