---
// src/pages/index.astro
// HOME PAGE
// ─────────────────────────────────────────────────────────────
// If you have a Layout component, replace the raw <html> shell
// below with: import Layout from '../layouts/Layout.astro'
// and wrap the body content in <Layout title="..." description="...">.
// ─────────────────────────────────────────────────────────────

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { ArrowRight } from 'lucide-astro';
import { User } from 'lucide-astro';
import { Lock } from 'lucide-astro';
import { MessageSquare } from 'lucide-astro';

const title = "Software Development for Apple Platforms | Curvachip";
const description =
  "Curvachip LLC crafts exceptional, privacy-first software for Apple platforms. Built by an indie developer who believes great apps should be secure, beautiful, and honest.";

const apps = [
  {
    name: "Shadow Task",
    tagline: "Focus & Track",
    blurb:
      "A Pomodoro timer with identifiable tasks, progress tracking, and personal quote prompts — all stored entirely on-device.",
    href: "/apps/shadow-task",
    iconUrl: "shadow-task.png",
  },
  {
    name: "TipZap",
    tagline: "Tip Calculator",
    blurb:
      "Split dinner costs, round totals, and calculate tips in seconds. The number pad is built right in.",
    href: "/apps/tipzap",
    iconUrl: "tipzap.png",
  },
  {
    name: "StoneClip",
    tagline: "Rock Identifier",
    blurb:
      "Point your camera at any rock and get an AI-powered identification with full geological context, instantly.",
    href: "/apps/stoneclip",
    iconUrl: "stoneclip.png",
  },
];

const values = [
  {
    label: "User-Focused Design",
    body: "Every decision — layout, color, copy — is made with a single question in mind: does this make it easier for the user?",
    icon: "◎",
  },
  {
    label: "Privacy by Default",
    body: "On-device processing wherever possible. No silent collection. What stays on your device stays on your device.",
    icon: "◈",
  },
  {
    label: "Feedback-Driven",
    body: "Criticism is a gift. Every App Store review, every email, every bug report shapes the next update.",
    icon: "◬",
  },
];
---

<Layout
  title={title}
  description={description}
  activeNav="home"
  canonicalUrl="https://curvachip.com/"
>

  <!-- ── HERO ────────────────────────────────────────────────── -->
   <Hero
    eyebrow="Apple Platforms · Est. 2024"
    title="Software built<br /><em>around&nbsp;you</em>"
    subtitle="Curvachip distributes privacy-first apps on the App Store — designed for 
    utility, built with care, and shaped by the people who use them."
  >
    <!-- Buttons go in the slot -->
    <div class="hero-cta">
      <a href="/apps"  class="btn btn-primary">Explore Apps</a>
      <a href="/about" class="btn btn-ghost">Our Story</a>
    </div>
  </Hero>
  <!-- <section class="hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container hero-content">
      <p class="eyebrow">Apple Platforms · Est. 2024</p>
      <h1 class="hero-title">Software built<br /><em>around&nbsp;you</em></h1>
      <p class="hero-sub">
        Curvachip distributes privacy-first apps on the App Store — designed for
        utility, built with care, and shaped by the people who use them.
      </p>
      <div class="hero-cta">
        <a href="/apps" class="btn btn-primary">Explore Apps</a>
        <a href="/about" class="btn btn-ghost">Our Story</a>
      </div>
    </div>
  </section> -->

  <!-- ── VALUES ──────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What we stand for</h2>
      <div class="values-grid">
        {
          values.map((v) => (
            <div class="value-card">
              <span class="value-icon" aria-hidden="true">
                {v.icon}
              </span>
              <h3 class="value-label">{v.label}</h3>
              <p class="value-body">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── FEATURED APPS ───────────────────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Featured apps</h2>
      <p class="section-sub">
        Every app is built for a purpose — vetted, designed, and submitted to
        the App Store with intention.
      </p>
      <div class="apps-grid">
        {
          apps.map((app) => (
            <a href={app.href} class="app-card">
              <span class="app-emoji" aria-hidden="true">
                <img src={app.iconUrl} alt={app.name} width="45" height="45" />
              </span>
              <div>
                <p class="app-tagline">{app.tagline}</p>
                <h3 class="app-name">{app.name}</h3>
                <p class="app-blurb">{app.blurb}</p>
              </div>
              <span class="app-arrow" aria-hidden="true">
                →
                {/* <ArrowRight size={16} /> */}
              </span>
            </a>
          ))
        }
      </div>
      <div class="cta-row">
        <a href="/apps" class="btn btn-primary">See all apps</a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIAL ─────────────────────────────────────────── -->
  <section class="section">
    <div class="container testimonial-wrap">
      <blockquote class="testimonial">
        <p class="testimonial-quote">
          "We all enjoyed and appreciated Michael's preparation, his earnest
          interest in listening, and his thoughtful dialogue … he is ready to
          GO!"
        </p>
        <footer class="testimonial-footer">
          <cite>
            Cathy Hayes — <a
              href="https://www.hayesstudio.com/home"
              target="_blank"
              rel="noopener">Hayes Inc.</a
            >
          </cite>
        </footer>
      </blockquote>
    </div>
  </section>


</Layout>

<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ─────────────────────────────────────────────────────────
     All custom properties are defined on :root so any nested
     page or component can reference them. If you move content
     into a layout component, move the :root block there too.
     ═══════════════════════════════════════════════════════════ -->

<style>
  /* ── HERO ── */
  
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── SECTIONS ── */
  .section {
    padding: clamp(4rem, 9vw, 7rem) 0;
  }
  .section-alt {
    background: var(--cc-surface);
  }
  .section-title {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }
  .section-sub {
    color: var(--cc-muted);
    max-width: 520px;
    margin-bottom: 3rem;
    font-size: 1rem;
  }

  /* ── VALUES ── */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .value-card {
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 2rem 1.75rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }
  .value-card:hover {
    border-color: rgba(91, 156, 246, 0.4);
    box-shadow: 0 0 24px rgba(91, 156, 246, 0.07);
  }
  .value-icon {
    display: block;
    font-size: 1.5rem;
    color: var(--cc-blue);
    margin-bottom: 1rem;
    line-height: 1;
  }
  .value-label {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  .value-body {
    color: var(--cc-muted);
    font-size: 0.9rem;
  }

  /* ── APPS GRID ── */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .app-card {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 1rem;
    align-items: start;
    background: var(--cc-bg);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 1.5rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    cursor: pointer;
  }
  .app-card:hover {
    border-color: rgba(91, 156, 246, 0.4);
    box-shadow: 0 0 20px rgba(91, 156, 246, 0.08);
  }
  .app-emoji {
    font-size: 1.75rem;
    line-height: 1;
    margin-top: 0.15rem;
  }
  .app-tagline {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cc-blue);
    margin-bottom: 0.2rem;
  }
  .app-name {
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .app-blurb {
    color: var(--cc-muted);
    font-size: 0.85rem;
  }
  .app-arrow {
    color: var(--cc-muted);
    margin-top: 0.25rem;
    transition:
      color 0.15s,
      transform 0.15s;
  }
  .app-card:hover .app-arrow {
    color: var(--cc-blue);
    transform: translateX(3px);
  }

  .cta-row {
    text-align: center;
  }

  /* ── TESTIMONIAL ── */
  .testimonial-wrap {
    max-width: 700px;
  }
  .testimonial {
    border-left: 3px solid var(--cc-blue);
    padding-left: 2rem;
  }
  .testimonial-quote {
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    font-style: italic;
    color: var(--cc-text);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .testimonial-footer cite {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--cc-muted);
  }
  .testimonial-footer a {
    color: var(--cc-blue);
  }
</style>
