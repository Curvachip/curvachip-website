    href:    "https://github.com/Curvachip",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>`,
    display: "Curvachip",
  },
  {
    label:   "LinkedIn",
    href:    "https://www.linkedin.com/company/curvachip",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    display: "Curvachip LLC",
  },
  {
    label:   "X / Twitter",
    href:    "https://x.com/curvachip",
    abbr:    `𝕏`,
    display: "@curvachip",
  },
  {
    label:   "Instagram",
    href:    "https://www.instagram.com/curvachip/",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
    display: "@curvachip",
  },
  {
    label:   "YouTube",
    href:    "https://www.youtube.com/@curvachip",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    display: "@curvachip",
  },
  {
    label:   "TikTok",
    href:    "https://www.tiktok.com/@curvachip",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.87a8.18 8.18 0 004.78 1.52V7a4.85 4.85 0 01-1.01-.31z"/></svg>`,
    display: "@curvachip",
  },
  {
    label:   "App Store",
    href:    "https://apps.apple.com/fi/developer/curvachip-llc/id1774903560",
    abbr:    ``,
    display: "Curvachip LLC",
  },
  {
    label:   "Spotify",
    href:    "https://open.spotify.com/user/31dvsb5yckqhavs7rhxm7ow6g7ny",
    abbr:    `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>`,
    display: "Curvachip",
  },
];

const reasons = [
    {
        icon: Bug,
        label: "Bug reports",
        body: "Found something broken in one of our apps? Tell us exactly what happened and which device you're on.",
    },
    {
        icon: MessagesSquare,
        label: "App feedback",
        body: "A feature you'd love to see, a design detail that confused you, or just general praise — we read it all.",
    },
    {
        icon: Handshake,
        label: "Business enquiries",
        body: "Partnerships, press, or collaboration opportunities — reach out and let's talk.",
    },
    {
        icon: Monitor,
        label: "Technical questions",
        body: "Questions about Swift, SwiftUI, or Apple development? We're happy to point you in the right direction.",
    },
];
---

<Layout
    title={title}
    description={description}
    activeNav="contact"
    canonicalUrl="https://curvachip.com/contact"
>
    <!-- ── HERO ── -->
    <Hero
        eyebrow="Get in touch"
        title="We read<br /><em>every email</em>"
        subtitle="Whether you've found a bug, have a feature idea, or just
                want to say hello — we're a small team and genuinely care
                about what you have to say."
    />

    <!-- ── MAIN CONTENT ── -->
    <main>
        <section class="section">
            <div class="container contact-layout">
                <!-- LEFT: FORM -->
                <div class="contact-form-col">
                    <h2 class="col-title">Send a message</h2>
                    <p class="col-sub">
                        Fill out the form below and your default mail client
                        will open with everything pre-filled. Alternatively,
                        email <a
                            href="mailto:developer@curvachip.com"
                            class="inline-link">developer@curvachip.com</a
                        > directly.
                    </p>

                    <!--
          IMPORTANT: This form uses a mailto: action, which opens the user's mail client.
          To use a real backend form service, see the comment at the top of this file.
        -->
                    <div class="form-shell">
                        <div class="form-group">
                            <label for="contact-name" class="form-label"
                                >Your name</label
                            >
                            <input
                                type="text"
                                id="contact-name"
                                name="name"
                                class="form-input"
                                placeholder="Ada Lovelace"
                                autocomplete="name"
                            />
                        </div>
                        <div class="form-group">
                            <label for="contact-email" class="form-label"
                                >Email address <span
                                    class="required"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <input
                                type="email"
                                id="contact-email"
                                name="email"
                                class="form-input"
                                placeholder="you@example.com"
                                autocomplete="email"
                                required
                            />
                        </div>
                        <div class="form-group">
                            <label for="contact-subject" class="form-label"
                                >Subject</label
                            >
                            <select
                                id="contact-subject"
                                name="subject"
                                class="form-input form-select"
                            >
                                <option value="">Select a reason…</option>
                                <option value="Bug report">Bug report</option>
                                <option value="App feedback"
                                    >App feedback</option
                                >
                                <option value="Feature request"
                                    >Feature request</option
                                >
                                <option value="Business enquiry"
                                    >Business enquiry</option
                                >
                                <option value="Technical question"
                                    >Technical question</option
                                >
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="contact-message" class="form-label"
                                >Message <span
                                    class="required"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <textarea
                                id="contact-message"
                                name="message"
                                class="form-input form-textarea"
                                placeholder="Tell us what's on your mind…"
                                rows="6"
                                required></textarea>
                        </div>
                        <!-- mailto submit — JavaScript assembles the mailto link from the form fields -->
                        <button
                            type="button"
                            class="btn btn-primary btn-full"
                            id="send-btn"
                        >
                            Send Message
                        </button>
                        <p class="form-note">
                            This button opens your mail client. Your message
                            won't be sent until you press Send in your email
                            app.
                        </p>
                    </div>
                </div>

                <!-- RIGHT: DIRECT CONTACT + SOCIALS -->
                <div class="contact-info-col">
                    <div class="direct-email-card">
                        <p class="direct-label">Direct email</p>
                        <a
                            href="mailto:developer@curvachip.com"
                            class="direct-address"
                        >
                            developer@curvachip.com
                        </a>
                        <p class="direct-note">
                            Usually responds within 2 business days.
                        </p>
                    </div>

                    <h3 class="col-title col-title--sm">
                        What to reach out about
                    </h3>
                    <ul class="reasons-list" role="list">
                        {
                            reasons.map((r) => (
                                <li class="reason-item">
                                    <span
                                        class="reason-icon"
                                        aria-hidden="true"
                                    >
                                        <r.icon size={18}/>
                                    </span>
                                    <div>
                                        <strong class="reason-label">
                                            {r.label}
                                        </strong>
                                        <p class="reason-body">{r.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>

                    <h3
                        class="col-title col-title--sm"
                        style="margin-top: 2.5rem"
                    >
                        Find us elsewhere
                    </h3>
                    <ul class="socials-list" role="list">
                        {
                            socials.map((s) => (
                                <li>
                                    <a
                                        href={s.href}
                                        class="social-row"
                                        target={
                                            s.href.startsWith("mailto")
                                                ? "_self"
                                                : "_blank"
                                        }
                                        rel="noopener"
                                        aria-label={s.label}
                                    >
                                        <span
                                            class="social-abbr"
                                            aria-hidden="true"
                                        >
                                            <Fragment set:html={s.abbr} />
                                        </span>
                                        <div>
                                            <span class="social-label">
                                                {s.label}
                                            </span>
                                            <span class="social-display">
                                                {s.display}
                                            </span>
                                        </div>
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </section>
    </main>

    <!-- mailto form assembly script -->
    <script>
        const btn = document.getElementById("send-btn");
        if (btn) {
            btn.addEventListener("click", () => {
                const name =
                    (
                        document.getElementById(
                            "contact-name",
                        ) as HTMLInputElement
                    )?.value.trim() || "";
                const email =
                    (
                        document.getElementById(
                            "contact-email",
                        ) as HTMLInputElement
                    )?.value.trim() || "";
                const subject =
                    (
                        document.getElementById(
                            "contact-subject",
                        ) as HTMLSelectElement
                    )?.value || "Enquiry";
                const message =
                    (
                        document.getElementById(
                            "contact-message",
                        ) as HTMLTextAreaElement
                    )?.value.trim() || "";

                if (!email || !message) {
                    alert(
                        "Please fill in your email address and message before sending.",
                    );
                    return;
                }

                const body = `From: ${name || "Not provided"}\nEmail: ${email}\n\n${message}`;
                const mailto = `mailto:developer@curvachip.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
                window.location.href = mailto;
            });
        }
    </script>
</Layout>

<style>

    .section {
        padding: clamp(5rem, 10vw, 8rem) 0;
    }
    .contact-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }
    @media (max-width: 768px) {
        .contact-layout {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }

    .col-title {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: -0.015em;
        margin-bottom: 0.6rem;
    }
    .col-title--sm {
        font-size: 1rem;
    }
    .col-sub {
        font-size: 0.875rem;
        color: var(--cc-muted);
        margin-bottom: 1.75rem;
    }
    .inline-link {
        color: var(--cc-blue);
    }
    .inline-link:hover {
        text-decoration: underline;
    }

    /* Form */
    .form-shell {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .form-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--cc-text);
    }
    .required {
        color: #ef4444;
    }
    .form-input {
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: 8px;
        padding: 0.65rem 0.9rem;
        color: var(--cc-text);
        font-size: 0.9rem;
        font-family: var(--font-body);
        width: 100%;
        transition:
            border-color 0.15s,
            box-shadow 0.15s;
        outline: none;
    }
    .form-input::placeholder {
        color: var(--cc-muted);
    }
    .form-input:focus {
        border-color: var(--cc-blue);
        box-shadow: 0 0 0 3px rgba(91, 156, 246, 0.12);
    }
    .form-select {
        appearance: none;
        cursor: pointer;
    }
    .form-textarea {
        resize: vertical;
        min-height: 130px;
    }
    .btn-full {
        width: 100%;
        justify-content: center;
        margin-top: 0.25rem;
    }
    .form-note {
        font-size: 0.78rem;
        color: var(--cc-muted);
        text-align: center;
        margin-top: 0.25rem;
    }

    /* Direct email */
    .direct-email-card {
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 1.5rem;
        margin-bottom: 2.5rem;
    }
    .direct-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cc-muted);
        margin-bottom: 0.4rem;
    }
    .direct-address {
        font-size: 1rem;
        font-weight: 600;
        color: var(--cc-blue);
        display: block;
        margin-bottom: 0.5rem;
    }
    .direct-address:hover {
        text-decoration: underline;
    }
    .direct-note {
        font-size: 0.8rem;
        color: var(--cc-muted);
    }

    /* Reasons */
    .reasons-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }
    .reason-item {
        display: flex;
        gap: 0.85rem;
        align-items: flex-start;
    }
    .reason-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
        color: var(--cc-green);
    }
    .reason-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }
    .reason-body {
        font-size: 0.825rem;
        color: var(--cc-muted);
        line-height: 1.6;
    }

    /* Social rows */
    .socials-list {
        list-style: none;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
    }
    @media (max-width: 480px) {
        .socials-list {
            grid-template-columns: 1fr;
        }
    }
    .social-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0.75rem;
        border-radius: 8px;
        border: 1px solid transparent;
        transition:
            background 0.15s,
            border-color 0.15s;
    }
    .social-row:hover {
        background: var(--cc-surface);
        border-color: var(--cc-border);
    }
    .social-abbr {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--cc-blue);
        flex-shrink: 0;
    }
    .social-row:hover .social-abbr {
        background: var(--cc-blue-dim);
        border-color: rgba(91, 156, 246, 0.3);
    }
    .social-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--cc-text);
    }
    .social-display {
        font-size: 0.75rem;
        color: var(--cc-muted);
    }
</style>
