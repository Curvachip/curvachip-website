// ── PROPS FOR CURRENT ROUTE ────────────────────────────────────
const {
    name,
    fullName,
    tagline,
    iconUrl,
    category,
    description,
    appStoreUrl,
    privacyUrl,
    canonicalUrl,
    platforms,
    price,
    minIos,
    rating,
    ratingCount,
    privacy,
    features,
    review,
    disclaimer,
} = Astro.props as AppDetail;

// Derived
const title = `${name} — ${tagline} | Curvachip`;
const metaDesc =
    description.slice(0, 155) + (description.length > 155 ? "…" : "");
const stars = "★".repeat(rating);
const privacyBadgeLabel =
    privacy === "none" ? "Data Not Collected" : "Data Not Linked to You";
const privacyBadgeColor = privacy === "none" ? "green" : "blue";
---

<Layout
    title={title}
    description={metaDesc}
    activeNav="apps"
    canonicalUrl={canonicalUrl}
    ogType="website"
>
    <!-- ── HERO ── -->
    <header class="app-hero">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="container app-hero-inner">
            <a href="/apps" class="back-link">← All apps</a>

            <div class="hero-top">
                <div aria-hidden="true">
                    <!-- <span class="app-icon-emoji">{iconUrl}</span> -->
                    <a
                        href={appStoreUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <Image src={iconUrl} alt={name} width="96" height="96" loading="eager" />
                    </a>
                </div>
                <div class="hero-meta">
                    <p class="hero-category">{category}</p>
                    <h1 class="hero-name">{name}</h1>
                    <p class="hero-tagline">{tagline}</p>
                    <div class="hero-badges">
                        {
                            platforms.map((p) => (
                                <span class="platform-badge">{p}</span>
                            ))
                        }
                        <span class="price-badge">{price}</span>
                    </div>
                </div>
            </div>

            <p class="hero-description">{description}</p>

            <div class="hero-actions">
                <!-- <a href={appStoreUrl} target="_blank" rel="noopener noreferrer">
                    <img src="/appblack.svg" alt={name} height="50" />
                </a> -->
                <a
                    href="#download-cta"
                    class="btn btn-primary btn-download"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                        ></path>
                    </svg>
                    Get {name}
                </a>
                <div
                    class="hero-rating"
                    aria-label={`Rated ${rating} out of 5 — ${ratingCount} ratings`}
                >
                    <span class="stars" aria-hidden="true">{stars}</span>
                    <span class="rating-count"
                        >{ratingCount} {ratingCount === 1 ? "rating" : "ratings"}</span
                    >
                </div>
            </div>
        </div>
    </header>

    <!-- ── FEATURES ── -->
    <section class="section" aria-label="Key features">
        <div class="container">
            <p class="section-eyebrow">What it does</p>
            <h2 class="section-title">Built for a purpose</h2>

            <div class="features-grid">
                {
                    features.map((f, i) => (
                        <div
                            class={`feature-row ${i % 2 === 1 ? "feature-row--flip" : ""}`}
                        >
                            <div class="feature-visual" aria-hidden="true">
                                <span class="feature-big-emoji">{f.icon}</span>
                            </div>
                            <div class="feature-text">
                                <h3 class="feature-title">{f.title}</h3>
                                <p class="feature-body">{f.body}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ── DISCLAIMER (AI/nature apps only) ── -->
    {
        disclaimer && (
            <section class="section section-tight">
                <div class="container">
                    <div class="disclaimer-card">
                        <span class="disclaimer-icon" aria-hidden="true">
                            ⚠
                        </span>
                        <div>
                            <strong>Important notice</strong>
                            <p>{disclaimer}</p>
                        </div>
                    </div>
                </div>
            </section>
        )
    }

    <!-- ── REVIEW ── -->
    {
        review && (
            <section class="section section-alt" aria-label="App Store review">
                <div class="container">
                    <p class="section-eyebrow">From the App Store</p>
                    <h2 class="section-title">What users say</h2>
                    <figure class="review-card">
                        <div
                            class="review-stars"
                            aria-label={`${review.stars} stars`}
                        >
                            {"★".repeat(review.stars)}
                        </div>
                        <blockquote class="review-quote">
                            <p>"{review.quote}"</p>
                        </blockquote>
                        <figcaption class="review-meta">
                            <strong>{review.author}</strong>
                            <span>{review.date} · App Store</span>
                        </figcaption>
                    </figure>
                </div>
            </section>
        )
    }

    <!-- ── APP INFO ── -->
    <section class="section" aria-label="App information">
        <div class="container info-layout">
            <div>
                <p class="section-eyebrow">App details</p>
                <h2 class="section-title">The essentials</h2>
                <p class="info-full-name">{fullName}</p>
                <p class="info-blurb">
                    Published by Curvachip LLC · Available on the Apple App
                    Store
                </p>
            </div>
            <dl class="info-grid">
                <div class="info-cell">
                    <dt>Category</dt>
                    <dd>{category}</dd>
                </div>
                <div class="info-cell">
                    <dt>Platforms</dt>
                    <dd>{platforms.join(", ")}</dd>
                </div>
                <div class="info-cell">
                    <dt>Price</dt>
                    <dd>{price}</dd>
                </div>
                <div class="info-cell">
                    <dt>Requires</dt>
                    <dd>{minIos} or later</dd>
                </div>
                <div class="info-cell">
                    <dt>Rating</dt>
                    <dd>
                        <span class="info-stars" aria-hidden="true"
                            >{"★".repeat(Math.round(rating))}</span
                        >
                        {" "}{rating.toFixed(1)} ({ratingCount})
                    </dd>
                </div>
                <div class="info-cell">
                    <dt>Privacy</dt>
                    <dd>
                        <span
                            class={`privacy-badge privacy-badge--${privacyBadgeColor}`}
                        >
                            {privacyBadgeLabel}
                        </span>
                    </dd>
                </div>
                <div class="info-cell info-cell--wide">
                    <dt>Copyright</dt>
                    <dd>
                        © {new Date().getFullYear()} Curvachip LLC. All rights reserved.
                    </dd>
                </div>
            </dl>
        </div>
    </section>

    <!-- ── FINAL CTA ── -->
    <section
        id="download-cta"
        class="section section-alt section-cta"
        aria-label="Download call to action"
    >
        <div class="container cta-inner">
            <!-- <span class="cta-emoji" aria-hidden="true">{iconUrl}</span> -->
            <a href={appStoreUrl} target="_blank" rel="noopener noreferrer">
                <Image src={iconUrl} alt={name} width="96" height="96" />
            </a>
            <h2 class="cta-title">Ready to try {name}?</h2>
            <p class="cta-sub">
                Free to download. Privacy by default. Built with care.
            </p>
            <div>
                <a href={appStoreUrl} target="_blank" rel="noopener noreferrer">
                    <img src="/appblack.svg" alt={name} height="55" loading="lazy"/>
                </a>
            </div>
        </div>
