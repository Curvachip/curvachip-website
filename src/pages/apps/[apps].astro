---
import Layout from "../../layouts/Layout.astro";

interface Highlight {
    icon: string;
    title: string;
    description: string;
}

interface Feature {
    eyebrow: string;
    title: string;
    description: string;
    image: string;
}

interface AppPage {
    appName: string;
    slug: string;

    tagline: string;
    heroDescription: string;

    iconUrl: string;

    appStoreUrl: string;
    privacyPolicyUrl: string;
    canonicalUrl: string;

    screenshots: string[];

    highlights: Highlight[];

    features: Feature[];

    perfectFor: string[];

    useFor: string[];

    category: string;
    price: string;
    compatibility: string;
    developer: string;

    privacySummary: string;
}

export function getStaticPaths() {
    const apps: { params: { apps: string }; props: AppPage }[] = [
        {
            params: {
                apps: "shadow-task",
            },

            props: {
                appName: "Shadow Task",
                slug: "shadow-task",

                tagline: "Focus & Track",

                heroDescription:
                    "A distraction-free Pomodoro timer designed to help you study, work, and build consistent focus without unnecessary clutter.",

                iconUrl: "/shadow-task.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/study-timer-shadow-task/id6737145799",

                privacyPolicyUrl: "/privacy/shadow-task",

                canonicalUrl: "https://curvachip.com/apps/shadow-task",

                screenshots: [
                    "/screenshots/shadow-task/1.png",
                    "/screenshots/shadow-task/2.png",
                    "/screenshots/shadow-task/3.png",
                    "/screenshots/shadow-task/4.png",
                ],

                highlights: [
                    {
                        icon: "⏱️",
                        title: "Pomodoro Sessions",
                        description:
                            "Stay focused using customizable work and break intervals.",
                    },
                    {
                        icon: "✓",
                        title: "Task Tracking",
                        description:
                            "Organize today's work while keeping your focus uninterrupted.",
                    },
                    {
                        icon: "📈",
                        title: "Daily Progress",
                        description:
                            "Watch your completed sessions build productive habits.",
                    },
                    {
                        icon: "🔒",
                        title: "Private",
                        description:
                            "Everything stays on your device. No accounts. No tracking.",
                    },
                ],

                features: [
                    {
                        eyebrow: "Focus",
                        title: "Stay in the zone.",
                        description:
                            "Start a session with one tap, eliminate distractions, and work until the timer finishes.",
                        image: "/screenshots/shadow-task/feature-1.png",
                    },
                    {
                        eyebrow: "Organize",
                        title: "Know exactly what you're working on.",
                        description:
                            "Assign tasks to every focus session so your progress stays intentional.",
                        image: "/screenshots/shadow-task/feature-2.png",
                    },
                    {
                        eyebrow: "Improve",
                        title: "Small sessions become big results.",
                        description:
                            "Track completed Pomodoros and build consistency over time.",
                        image: "/screenshots/shadow-task/feature-3.png",
                    },
                ],

                perfectFor: [
                    "Students",
                    "Developers",
                    "Writers",
                    "Professionals",
                ],

                useFor: [
                    "Deep Work",
                    "Homework",
                    "Study Sessions",
                    "Exams",
                ],

                category: "Productivity",
                price: "Free",
                compatibility: "iPhone • iOS 18+",
                developer: "Curvachip LLC",

                privacySummary:
                    "Shadow Task stores all information locally on your device. No accounts, analytics, advertising, or tracking.",
            },
        },
    ];

    return apps;
}

const {
    appName,
    tagline,
    heroDescription,

    iconUrl,

    appStoreUrl,
    privacyPolicyUrl,
    canonicalUrl,

    screenshots,

    highlights,

    features,

    perfectFor,

    useFor,

    category,
    price,
    compatibility,
    developer,

    privacySummary,
} = Astro.props as AppPage;

const title = `${appName} | Curvachip`;
const description = heroDescription;
---

<Layout
    title={title}
    description={description}
    canonicalUrl={canonicalUrl}
    activeNav="apps"
>
    <header class="app-hero">
        <div class="hero-glow"></div>

        <div class="container hero-inner">
            <a href="/apps" class="back-link"> ← Back to Apps </a>

            <div class="hero-grid">
                <div class="hero-copy">
                    <div class="app-ident">
                        <img
                            src={iconUrl}
                            alt={appName}
                            width="84"
                            height="84"
                        />

                        <div>
                            <p class="app-tagline">
                                {tagline}
                            </p>

                            <h1>
                                {appName}
                            </h1>
                        </div>
                    </div>

                    <p class="hero-description">
                        {heroDescription}
                    </p>

                    <div class="hero-actions">
                        <a
                            class="btn"
                            href={appStoreUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            Download on the App Store
                        </a>

                        <a class="btn btn-ghost" href={privacyPolicyUrl}>
                            Privacy Policy
                        </a>
                    </div>
                </div>

                <div class="hero-preview">
                    <img src={screenshots[0]} alt={`${appName} screenshot`} />
                </div>
            </div>
        </div>
    </header>

    <main>
        <div class="container">
            <section class="screenshots">
                <div class="section-header">
                    <p class="section-label">Gallery</p>

                    <h2>Take a closer look.</h2>
                </div>

                <div class="screenshot-strip">
                    {
                        screenshots.map((shot) => (
                            <img src={shot} alt="" loading="lazy" />
                        ))
                    }
                </div>
            </section>

            <section class="highlights">
                <div class="section-header">
                    <p class="section-label">Highlights</p>

                    <h2>Everything you need. Nothing you don't.</h2>
                </div>

                <div class="highlight-grid">
                    {
                        highlights.map((item) => (
                            <article class="highlight-card">
                                <div class="highlight-icon">{item.icon}</div>

                                <h3>{item.title}</h3>

                                <p>{item.description}</p>
                            </article>
                        ))
                    }
                </div>
            </section>

            <section class="feature-list">
                {
                    features.map((feature, index) => (
                        <section
                            class={`feature-row ${
                                index % 2 === 1 ? "reverse" : ""
                            }`}
                        >
                            <div class="feature-copy">
                                <p class="section-label">{feature.eyebrow}</p>

                                <h2>{feature.title}</h2>

                                <p>{feature.description}</p>
                            </div>

                            <div class="feature-image">
                                <img
                                    src={feature.image}
                                    alt={feature.title}
                                    loading="lazy"
                                />
                            </div>
                        </section>
                    ))
                }
            </section>

            <section class="perfect-for">
                <div class="section-header">
                    <p class="section-label">Built For</p>

                    <h2>Users like you...</h2>
                </div>

                <div class="pill-grid">
                    {perfectFor.map((item) => <span class="pill">{item}</span>)}
                </div>
            </section>

            <section class="perfect-for">
                <div class="section-header">
                    <p class="section-label">Covering</p>

                    <h2>Tasks like these...</h2>
                </div>

                <div class="pill-grid">
                    {useFor.map((item) => <span class="pill">{item}</span>)}
                </div>
            </section>

            <section class="privacy-summary">
                <div class="privacy-card">
                    <div class="privacy-header">
                        <div class="privacy-icon">🔒</div>

                        <div>
                            <p class="section-label">Privacy</p>

                            <h2>Your data stays yours.</h2>
                        </div>
                    </div>

                    <p class="privacy-description">
                        {privacySummary}
                    </p>

                    <ul class="privacy-list">
                        <li>✓ No ads</li>

                        <li>✓ No tracking</li>

                        <li>✓ No account required</li>

                        <li>✓ Privacy-first design</li>
                    </ul>

                    <a href={privacyPolicyUrl} class="btn btn-ghost">
                        Read Privacy Policy →
                    </a>
                </div>
            </section>

            <section class="app-information">
                <div class="section-header">
                    <p class="section-label">Information</p>

                    <h2>App details</h2>
                </div>

                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label"> Category </span>

                        <span class="info-value">
                            {category}
                        </span>
                    </div>

                    <div class="info-item">
                        <span class="info-label"> Price </span>

                        <span class="info-value">
                            {price}
                        </span>
                    </div>

                    <div class="info-item">
                        <span class="info-label"> Compatibility </span>

                        <span class="info-value">
                            {compatibility}
                        </span>
                    </div>

                    <div class="info-item">
                        <span class="info-label"> Developer </span>

                        <span class="info-value">
                            {developer}
                        </span>
                    </div>
                </div>
            </section>

            <section class="download-cta">
                <div class="cta-card">
                    <img src={iconUrl} alt={appName} width="72" height="72" />

                    <h2>Ready to get started?</h2>

                    <p>
                        Download <strong>{appName}</strong> today and start using
                        it in seconds.
                    </p>

                    <div class="cta-actions">
                        <a
                            href={appStoreUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <img
                                src="/appblack.svg"
                                alt={`Download ${appName} on the App Store`}
                                height="44"
                            />
                        </a>

                        <a href={privacyPolicyUrl} class="btn btn-ghost">
                            Privacy Policy
                        </a>

                        <a href="/apps" class="btn btn-ghost"> ← All Apps </a>
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>

<style>
    /* ═══════════════════════════════════════════════════════════════
       GLOBAL
       ═══════════════════════════════════════════════════════════════ */

    .section-header {
        max-width: 680px;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .section-label {
        display: inline-block;
        margin-bottom: 0.5rem;

        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;

        color: var(--cc-blue);
    }

    .section-header h2 {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.05;
        color: var(--cc-text);
    }

    .section-header p {
        margin-top: 1rem;
        color: var(--cc-muted);
        line-height: 1.8;
    }

    main > .container {
        display: flex;
        flex-direction: column;
        gap: clamp(5rem, 10vw, 8rem);
        padding-block: clamp(4rem, 7vw, 7rem);
    }

    /* ═══════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════ */

    .app-hero {
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--cc-border);

        padding-top: clamp(3rem, 7vw, 5rem);
        padding-bottom: clamp(4rem, 8vw, 6rem);
    }

    .hero-glow {
        position: absolute;
        inset: 0;

        pointer-events: none;

        background:
            radial-gradient(
                ellipse at top left,
                rgba(91, 156, 246, 0.12),
                transparent 65%
            ),
            radial-gradient(
                ellipse at bottom right,
                rgba(91, 156, 246, 0.06),
                transparent 70%
            );
    }

    .hero-inner {
        position: relative;
        z-index: 1;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 2.5rem;

        color: var(--cc-muted);
        font-size: 0.85rem;

        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--cc-blue);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: clamp(3rem, 8vw, 6rem);
        align-items: center;
    }

    .hero-copy {
        max-width: 560px;
    }

    .app-ident {
        display: flex;
        align-items: center;
        gap: 1rem;

        margin-bottom: 2rem;
    }

    .app-ident img {
        width: 84px;
        height: 84px;

        border-radius: 22px;

        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
    }

    .app-tagline {
        margin-bottom: 0.35rem;

        color: var(--cc-blue);

        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .app-ident h1 {
        font-family: var(--font-display);
        font-size: clamp(2.7rem, 6vw, 4.6rem);
        line-height: 0.95;
        letter-spacing: -0.045em;
        font-weight: 800;

        color: var(--cc-text);
    }

    .hero-description {
        margin: 2rem 0;

        color: var(--cc-muted);

        font-size: 1.08rem;
        line-height: 1.9;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
    }

    .hero-preview {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-preview img {
        width: 100%;
        max-width: 320px;

        border-radius: 28px;

        border: 1px solid var(--cc-border);

        box-shadow: 0 35px 80px rgba(0, 0, 0, 0.35);

        transition:
            transform 0.35s ease,
            box-shadow 0.35s ease;
    }

    .hero-preview img:hover {
        transform: translateY(-8px) rotate(-1deg);

        box-shadow: 0 45px 90px rgba(0, 0, 0, 0.42);
    }

    /* ═══════════════════════════════════════════════════════════════
       COMMON SECTION SPACING
       ═══════════════════════════════════════════════════════════════ */

    .screenshots,
    .highlights,
    .feature-list,
    .perfect-for,
    .privacy-summary,
    .app-information,
    .download-cta {
        scroll-margin-top: 90px;
    }

    /* ═══════════════════════════════════════════════════════════════
       RESPONSIVE (GLOBAL + HERO)
       ═══════════════════════════════════════════════════════════════ */

    @media (max-width: 960px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-copy {
            max-width: none;
        }

        .hero-preview {
            order: -1;
        }

        .hero-preview img {
            max-width: 280px;
        }
    }

    @media (max-width: 640px) {
        .app-ident {
            align-items: flex-start;
        }

        .app-ident img {
            width: 72px;
            height: 72px;
            border-radius: 18px;
        }

        .hero-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .hero-actions .btn {
            width: 100%;
            justify-content: center;
        }

        .section-header h2 {
            font-size: 2rem;
        }
    }

    /* ═══════════════════════════════════════════════════════════════
       SCREENSHOT GALLERY
       ═══════════════════════════════════════════════════════════════ */

    .screenshot-strip {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: minmax(220px, 260px);

        gap: 1.5rem;

        overflow-x: auto;
        overflow-y: hidden;

        padding: 0.5rem 0 1rem;

        scroll-snap-type: x proximity;
        scrollbar-width: thin;
    }

    .screenshot-strip::-webkit-scrollbar {
        height: 8px;
    }

    .screenshot-strip::-webkit-scrollbar-thumb {
        background: var(--cc-border);
        border-radius: 999px;
    }

    .screenshot-strip img {
        width: 100%;
        display: block;

        border-radius: 24px;
        border: 1px solid var(--cc-border);

        background: var(--cc-surface);

        scroll-snap-align: start;

        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);

        transition:
            transform 0.28s ease,
            box-shadow 0.28s ease,
            border-color 0.28s ease;
    }

    .screenshot-strip img:hover {
        transform: translateY(-6px) scale(1.015);

        border-color: rgba(91, 156, 246, 0.35);

        box-shadow: 0 28px 60px rgba(0, 0, 0, 0.3);
    }

    /* ═══════════════════════════════════════════════════════════════
       HIGHLIGHTS
       ═══════════════════════════════════════════════════════════════ */

    .highlight-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .highlight-card {
        position: relative;

        display: flex;
        flex-direction: column;

        padding: 1.75rem;

        border-radius: 18px;

        background: var(--cc-surface);
        border: 1px solid var(--cc-border);

        transition:
            transform 0.25s ease,
            border-color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .highlight-card:hover {
        transform: translateY(-4px);

        border-color: rgba(91, 156, 246, 0.35);

        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    }

    .highlight-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;

        width: 52px;
        height: 52px;

        margin-bottom: 1.25rem;

        border-radius: 14px;

        background: linear-gradient(
            180deg,
            rgba(91, 156, 246, 0.18),
            rgba(91, 156, 246, 0.08)
        );

        border: 1px solid rgba(91, 156, 246, 0.18);

        font-size: 1.35rem;
    }

    .highlight-card h3 {
        margin-bottom: 0.75rem;

        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: -0.02em;

        color: var(--cc-text);
    }

    .highlight-card p {
        color: var(--cc-muted);

        font-size: 0.94rem;
        line-height: 1.75;

        flex: 1;
    }

    /* subtle top accent */

    .highlight-card::before {
        content: "";

        position: absolute;

        top: 0;
        left: 24px;
        right: 24px;

        height: 2px;

        border-radius: 999px;

        background: linear-gradient(
            90deg,
            transparent,
            rgba(91, 156, 246, 0.9),
            transparent
        );

        opacity: 0;

        transition: opacity 0.25s ease;
    }

    .highlight-card:hover::before {
        opacity: 1;
    }

    /* ═══════════════════════════════════════════════════════════════
       RESPONSIVE
       ═══════════════════════════════════════════════════════════════ */

    @media (max-width: 1100px) {
        .highlight-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 700px) {
        .highlight-grid {
            grid-template-columns: 1fr;
        }

        .highlight-card {
            padding: 1.5rem;
        }

        .screenshot-strip {
            grid-auto-columns: minmax(180px, 220px);
        }
    }

    /* ════════════════════════════════════════════════════════════════
   HERO
   ════════════════════════════════════════════════════════════════ */

    .app-hero {
        position: relative;
        overflow: hidden;
        padding: clamp(4rem, 8vw, 7rem) 0;
        border-bottom: 1px solid var(--cc-border);
    }

    .hero-glow {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(
                circle at 15% 25%,
                rgba(91, 156, 246, 0.12),
                transparent 45%
            ),
            radial-gradient(
                circle at 85% 75%,
                rgba(91, 156, 246, 0.06),
                transparent 40%
            );
    }

    .app-hero-inner {
        position: relative;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 4rem;
        align-items: center;
    }

    @media (max-width: 900px) {
        .app-hero-inner {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }

    .back-link {
        display: inline-block;
        color: var(--cc-muted);
        font-size: 0.82rem;
        margin-bottom: 1.5rem;
        transition: color 0.18s;
    }

    .back-link:hover {
        color: var(--cc-blue);
    }

    .hero-tag {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--cc-blue);
        font-weight: 700;
        margin-bottom: 0.8rem;
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        line-height: 1;
        letter-spacing: -0.04em;
        margin-bottom: 1.25rem;
    }

    .hero-description {
        max-width: 620px;
        color: var(--cc-muted);
        font-size: 1.05rem;
        line-height: 1.85;
        margin-bottom: 2rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
    }

    .hero-actions img {
        display: block;
    }

    .hero-phone {
        display: flex;
        justify-content: center;
    }

    .phone-frame {
        width: min(360px, 100%);
        aspect-ratio: 9 / 19.5;
        border-radius: 40px;
        overflow: hidden;
        border: 1px solid var(--cc-border);
        background: var(--cc-surface);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
    }

    .phone-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* ════════════════════════════════════════════════════════════════
   FEATURE SECTIONS
   ════════════════════════════════════════════════════════════════ */

    .features {
        padding: clamp(4rem, 8vw, 7rem) 0;
    }

    .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
        margin-bottom: clamp(5rem, 10vw, 8rem);
    }

    .feature-row:last-child {
        margin-bottom: 0;
    }

    .feature-row.reverse {
        direction: rtl;
    }

    .feature-row.reverse > * {
        direction: ltr;
    }

    @media (max-width: 900px) {
        .feature-row,
        .feature-row.reverse {
            grid-template-columns: 1fr;
            gap: 2rem;
            direction: ltr;
        }
    }

    .feature-image {
        border-radius: var(--cc-radius);
        overflow: hidden;
        border: 1px solid var(--cc-border);
        background: var(--cc-surface);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    }

    .feature-image img {
        width: 100%;
        display: block;
    }

    .feature-tag {
        color: var(--cc-blue);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .feature-title {
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 1.15;
        margin-bottom: 1rem;
        letter-spacing: -0.03em;
    }

    .feature-description {
        color: var(--cc-muted);
        line-height: 1.9;
        margin-bottom: 1.5rem;
    }

    .feature-list {
