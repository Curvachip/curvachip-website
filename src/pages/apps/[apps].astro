---
// src/pages/apps/[app].astro
// ═══════════════════════════════════════════════════════════════
// DYNAMIC APP DETAIL PAGE
// ───────────────────────────────────────────────────────────────
// Generates one landing page per app at /apps/<slug>.
// Each page has: hero, alternating feature sections, App Store
// review, app info panel, and a final download CTA.
//
// TO ADD A NEW APP: copy one entry in getStaticPaths(), update
// every field, and run `astro build`. The new URL appears
// automatically.
// ═══════════════════════════════════════════════════════════════

import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

// ── TYPES ──────────────────────────────────────────────────────

interface Feature {
    icon: string; // emoji
    title: string;
    body: string;
}

interface Review {
    quote: string;
    author: string;
    date: string;
    stars: number;
}

interface AppDetail {
    // Identity
    name: string; // display name, e.g. "Shadow Task"
    fullName: string; // App Store title, e.g. "Study Timer - Shadow Task"
    tagline: string; // subtitle shown under name
    iconUrl: string;
    category: string; // "Productivity" | "Finance" | "Education" | etc.
    description: string; // hero paragraph — the core value proposition
    // URLs
    appStoreUrl: string;
    privacyUrl: string;
    canonicalUrl: string;
    // Meta
    platforms: string[]; // ["iPhone", "iPad", "Mac", "Apple Watch"]
    price: string; // "Free" | "Free · In‑App Purchases"
    minIos: string; // "iOS 17.6"
    rating: number;
    ratingCount: number;
    privacy: "none" | "not-linked"; // "none" = Data Not Collected
    // Content
    features: Feature[];
    review: Review | null;
    // Optional — shown as a safety callout for AI / nature apps
    disclaimer?: string;
}

// ── ROUTE DEFINITIONS ──────────────────────────────────────────

export function getStaticPaths() {
    const apps: { params: { apps: string }; props: AppDetail }[] = [
        // ── SHADOW TASK ───────────────────────────────────────────
