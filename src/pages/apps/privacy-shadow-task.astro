---
// src/pages/privacy-policy-[appname].astro
// ═══════════════════════════════════════════════════════════════
// PRIVACY POLICY TEMPLATE
// ───────────────────────────────────────────────────────────────
// HOW TO USE THIS TEMPLATE:
//   1. Duplicate this file and rename it, e.g. privacy-policy-shadowtask.astro
//   2. Fill in every value marked with  ← UPDATE  below.
//   3. In the "dataItems" array, keep only the rows that apply
//      to your app and delete the rest.
//   4. Set aiProcessing = true if the app sends data to an AI API.
//   5. Update the lastUpdated date whenever you publish a change.
// ═══════════════════════════════════════════════════════════════

// ── FILL THESE IN ──────────────────────────────────────────────
const appName       = "Shadow Task";                    // ← UPDATE: the app's display name
const appTagline    = "Focus & Track";                  // ← UPDATE: one-line descriptor
const appEmoji      = "🌑";                             // ← UPDATE: the emoji used in your nav/apps page
const appStoreUrl   = "https://apps.apple.com/...";    // ← UPDATE: direct App Store link
const appPageUrl    = "/apps/privacy-shadow-task";                   // ← UPDATE: internal page path
const canonicalUrl  = "https://curvachip.com/apps/privacy-shadow-task"; // ← UPDATE
const lastUpdated   = "June 2025";                     // ← UPDATE: whenever you revise this policy
const contactEmail  = "developer@curvachip.com";       // leave as-is unless email changes

// ── DATA PRACTICES ─────────────────────────────────────────────
// Set to true if the app sends any data to an external AI API.
const aiProcessing  = false; // ← UPDATE

// Set to true if the app uses iCloud / CloudKit sync.
const icloudSync    = false; // ← UPDATE

// Set to true if the app uses any third-party SDKs (analytics, crash reporting, etc.)
const thirdParty    = false; // ← UPDATE

// ── DATA COLLECTED ─────────────────────────────────────────────
// Keep only the rows that apply. Delete the ones that don't.
// "stored" values: "on-device" | "external" | "none"
// "sharedWith" values: "nobody" | name the third party explicitly
const dataItems = [
  // Example on-device data — no collection:
  {
    category: "Task names & timer data",
    purpose:  "Core app functionality",
    stored:   "on-device",
    retained: "Until you delete the app",
    sharedWith: "nobody",
  },
  // Example: if your app uses AI, uncomment and fill in:
  // {
  //   category: "Camera images or text you submit",
  //   purpose:  "AI identification request",
  //   stored:   "external",
  //   retained: "Per the AI provider's retention policy (see below)",
  //   sharedWith: "OpenAI / Google Gemini / etc.",  // ← UPDATE to actual provider
  // },
  // Example: if you use analytics:
  // {
  //   category: "Anonymised usage events",
  //   purpose:  "Understanding how the app is used",
  //   stored:   "external",
  //   retained: "13 months",
  //   sharedWith: "TelemetryDeck / Mixpanel / etc.",  // ← UPDATE
  // },
];

// ── META ───────────────────────────────────────────────────────
const title       = `Privacy Policy — ${appName} | Curvachip`;
const description = `Privacy policy for ${appName} by Curvachip LLC. Learn exactly what data is collected, how it is used, and your rights as a user.`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Outfit:wght@600;700&display=swap" rel="stylesheet" />
  <link rel="canonical" href={canonicalUrl} />
</head>
<body>

<!-- ── NAV ── -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Curvachip home">
      <img
        src="/graphiclogodark.svg"
        alt="Curvachip logo"
        class="logo-chip"
      />
      <span class="logo-text">Curvachip</span>
    </a>
    <ul class="nav-links" id="nav-links">
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/apps" class="nav-link active">Apps</a></li>
      <li><a href="/privacy" class="nav-link">Privacy</a></li>
      <li><a href="/contact" class="nav-link">Contact</a></li>
      <li><a href="/about" class="nav-link">About</a></li>
    </ul>
    <button
      class="hamburger"
      id="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
    </button>
      </div>
        <!-- Mobile drawer — rendered below the bar, pushed out of flow -->
        <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
          <ul class="mobile-links">
            <li><a href="/" class="mobile-link">Home</a></li>
            <li><a href="/apps" class="mobile-link--active">Apps</a></li>
            <li><a href="/privacy" class="mobile-link">Privacy</a></li>
            <li><a href="/contact" class="mobile-link">Contact</a></li>
            <li><a href="/about" class="mobile-link">About</a></li>
           </ul>
        </div>
</nav>

<!-- ── HEADER ── -->
<header class="doc-hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container doc-hero-inner">
    <a href="/apps" class="back-link">← Back to Apps</a>
    <div class="app-ident">
      <span class="app-ident-emoji" aria-hidden="true">{appEmoji}</span>
      <div>
        <p class="app-ident-tagline">{appTagline}</p>
        <h1 class="app-ident-name">{appName}</h1>
      </div>
    </div>
    <h2 class="doc-title">Privacy Policy</h2>
    <p class="doc-meta">Curvachip LLC · Last updated: {lastUpdated}</p>
    <p class="doc-intro">
      This policy explains what data {appName} collects, why it collects it, and exactly what happens
      to it. There is no fine print. If anything here is unclear, email us and we will explain it.
    </p>
  </div>
</header>

<!-- ── BODY ── -->
<main>
  <div class="container doc-layout">

    <!-- TABLE OF CONTENTS -->
    <nav class="toc" aria-label="Table of contents">
      <p class="toc-title">On this page</p>
      <ol class="toc-list">
        <li><a href="#overview" class="toc-link">1. Overview</a></li>
        <li><a href="#data-collected" class="toc-link">2. What we collect</a></li>
        <li><a href="#data-use" class="toc-link">3. How we use it</a></li>
        {aiProcessing && <li><a href="#ai" class="toc-link">4. AI processing</a></li>}
        {icloudSync  && <li><a href="#icloud" class="toc-link">5. iCloud sync</a></li>}
        {thirdParty  && <li><a href="#third-party" class="toc-link">6. Third parties</a></li>}
        <li><a href="#retention" class="toc-link">7. Data retention</a></li>
        <li><a href="#rights" class="toc-link">8. Your rights</a></li>
        <li><a href="#children" class="toc-link">9. Children</a></li>
        <li><a href="#changes" class="toc-link">10. Changes to this policy</a></li>
        <li><a href="#contact" class="toc-link">11. Contact</a></li>
      </ol>
    </nav>

    <!-- DOCUMENT -->
    <article class="doc-body">

      <!-- 1. OVERVIEW -->
      <section id="overview" class="doc-section">
        <h2 class="doc-h2">1. Overview</h2>
        <p>
          {appName} is published by Curvachip LLC, a single-person software company. We are committed to
          limiting the data we collect as much as possible, processing data on-device wherever feasible, and being
          completely transparent about anything we do collect.
        </p>
        {!aiProcessing && !icloudSync && !thirdParty && (
          <div class="callout callout--green">
            <span class="callout-icon" aria-hidden="true">✓</span>
            <div>
              <strong>This app is fully on-device.</strong> {appName} does not send any data to
              Curvachip or any third party. Everything you do in the app stays on your device.
            </div>
          </div>
        )}
        {(aiProcessing || icloudSync || thirdParty) && (
          <div class="callout callout--blue">
            <span class="callout-icon" aria-hidden="true">◈</span>
            <div>
              <strong>Some data leaves your device.</strong> The sections below explain exactly
              what, why, and where it goes.
            </div>
          </div>
        )}
      </section>

      <!-- 2. DATA COLLECTED -->
      <section id="data-collected" class="doc-section">
        <h2 class="doc-h2">2. What we collect</h2>
        <p>
          The table below is a complete record of every category of data that {appName} collects
          or processes. If a category is not listed here, we do not collect it.
        </p>
        <div class="data-table-wrapper" role="region" aria-label="Data collection table" tabindex="0">
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">Data category</th>
                <th scope="col">Purpose</th>
                <th scope="col">Stored</th>
                <th scope="col">Retained</th>
                <th scope="col">Shared with</th>
              </tr>
            </thead>
            <tbody>
              {dataItems.map((row) => (
                <tr>
                  <td>{row.category}</td>
                  <td>{row.purpose}</td>
                  <td>
                    <span class={`badge badge--${row.stored === 'on-device' ? 'green' : row.stored === 'external' ? 'amber' : 'muted'}`}>
                      {row.stored}
                    </span>
                  </td>
                  <td>{row.retained}</td>
                  <td>{row.sharedWith}</td>
                </tr>
              ))}
              {dataItems.length === 0 && (
                <tr>
                  <td colspan="5" class="table-empty">No data is collected.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
        <p class="table-note">
          We never collect: your name, email address, phone number, location, contacts, photos
          (beyond what you explicitly submit to a feature), or any device identifier that could
          be used to track you across apps.
        </p>
      </section>

      <!-- 3. HOW WE USE IT -->
      <section id="data-use" class="doc-section">
        <h2 class="doc-h2">3. How we use it</h2>
        <p>
          Data is used solely to provide the features of {appName}. We do not:
        </p>
        <ul class="policy-list">
          <li>Sell your data to any party</li>
          <li>Use your data for advertising</li>
          <li>Build a profile of you across apps or sessions</li>
          <li>Share your data with anyone not listed in the table above</li>
          <li>Retain data beyond the period necessary for the feature it supports</li>
        </ul>
      </section>

      <!-- 4. AI PROCESSING (conditional) -->
      {aiProcessing && (
        <section id="ai" class="doc-section">
          <h2 class="doc-h2">4. AI processing</h2>
          <div class="callout callout--amber">
            <span class="callout-icon" aria-hidden="true">⚠</span>
            <div>
              <strong>Some data is processed by an external AI service.</strong> When you use the
              identification feature, the image or text you submit is sent to a third-party AI
              provider. It is not stored by Curvachip, but it is processed outside your device.
            </div>
          </div>
          <p>
            <!-- ← UPDATE: Replace [AI Provider Name] with the real provider (e.g. OpenAI, Google Gemini). -->
            {appName} uses <strong>[AI Provider Name]</strong> to process identification requests.
            The data sent consists of the image or text you explicitly submit by pressing the
            identification button. This data is:
          </p>
          <ul class="policy-list">
            <li>Transmitted over an encrypted HTTPS connection</li>
            <li>Processed by [AI Provider Name] under their own privacy policy: <a href="#" class="inline-link">[AI provider privacy policy URL]</a></li><!-- ← UPDATE -->
            <li>Not stored by Curvachip after the response is returned</li>
            <li>Not used to train Curvachip's own models (we don't have any)</li>
          </ul>
          <p>
            We recommend reviewing [AI Provider Name]'s privacy policy if you have concerns about
            how they handle submitted data on their end.
          </p>
        </section>
      )}

      <!-- 5. ICLOUD SYNC (conditional) -->
      {icloudSync && (
        <section id="icloud" class="doc-section">
          <h2 class="doc-h2">5. iCloud sync</h2>
          <p>
            {appName} uses Apple's CloudKit framework to sync your data across your devices via iCloud.
            This means your data is stored in your personal iCloud account — Curvachip cannot access it.
            Apple's iCloud is governed by <a href="https://www.apple.com/legal/privacy/" target="_blank" rel="noopener" class="inline-link">Apple's Privacy Policy</a>.
          </p>
          <p>
            You can disable iCloud sync for {appName} at any time in <strong>Settings → [Your Name] → iCloud</strong>
            on your device. Disabling sync does not delete data already on your device.
          </p>
        </section>
      )}

      <!-- 6. THIRD PARTIES (conditional) -->
      {thirdParty && (
        <section id="third-party" class="doc-section">
          <h2 class="doc-h2">6. Third-party services</h2>
          <p>
            <!-- ← UPDATE: List every SDK or service used and link to their privacy policies. -->
            {appName} uses the following third-party services. Each link goes to that service's own
            privacy policy:
          </p>
          <ul class="policy-list">
            <li><a href="#" class="inline-link">[Service Name] — [what it does]</a></li><!-- ← UPDATE -->
          </ul>
          <p>
            Curvachip chooses third-party services carefully and only includes those that are
            necessary for a specific feature. We do not use advertising SDKs.
          </p>
        </section>
      )}

      <!-- 7. RETENTION -->
      <section id="retention" class="doc-section">
        <h2 class="doc-h2">7. Data retention</h2>
        <p>
          On-device data is retained until you delete the app or manually clear it within the app's
          settings. Curvachip does not hold copies of on-device data and cannot recover it if you
          uninstall the app.
        </p>
        {aiProcessing && (
          <p>
            Data submitted to the AI identification feature is processed in real time and is not
            retained by Curvachip after the response is received. Retention by the AI provider is
            governed by their own policy (linked above).
          </p>
        )}
      </section>

      <!-- 8. YOUR RIGHTS -->
      <section id="rights" class="doc-section">
        <h2 class="doc-h2">8. Your rights</h2>
        <p>
          Depending on where you live, you may have rights under applicable privacy law (including
          GDPR, CCPA, or equivalent legislation). Because {appName} collects minimal data, most of
          these rights are satisfied automatically:
        </p>
        <ul class="policy-list">
          <li><strong>Access:</strong> On-device data is stored only on your device — you have direct access to it at all times.</li>
          <li><strong>Deletion:</strong> Delete the app to remove all on-device data. For any data held by a third party, contact that party directly.</li>
          <li><strong>Portability:</strong> On-device data is not locked in a proprietary format inaccessible to you.</li>
          <li><strong>Objection / opt-out:</strong> You can stop using any feature that processes data. AI features can be ignored without losing core functionality.</li>
        </ul>
        <p>
          To exercise any right or ask a question about your data, email us at <a href={`mailto:${contactEmail}`} class="inline-link">{contactEmail}</a>.
          We will respond within 30 days.
        </p>
      </section>

      <!-- 9. CHILDREN -->
      <section id="children" class="doc-section">
        <h2 class="doc-h2">9. Children</h2>
        <p>
          {appName} is not directed at children under 13. We do not knowingly collect any information
          from users under 13. If you believe a child has submitted data through this app, please
          contact us immediately at <a href={`mailto:${contactEmail}`} class="inline-link">{contactEmail} </a>
          and we will address it promptly.
        </p>
      </section>

      <!-- 10. CHANGES -->
      <section id="changes" class="doc-section">
        <h2 class="doc-h2">10. Changes to this policy</h2>
        <p>
          If this policy changes in a material way — for example, if a new feature requires
          collecting data that was not collected before — the new policy will be published on this
          page with an updated date at the top. Continued use of {appName} after such changes
          constitutes acceptance of the revised policy.
        </p>
        <p>
          We will not silently expand data collection. Any material change will be communicated
          via an App Store update note.
        </p>
      </section>

      <!-- 11. CONTACT -->
      <section id="contact" class="doc-section">
        <h2 class="doc-h2">11. Contact</h2>
        <p>
          Questions, concerns, or requests regarding this policy should be sent to:
        </p>
        <div class="contact-block">
          <p class="contact-line"><strong>Curvachip LLC</strong></p>
          <p class="contact-line">
            Email: <a href={`mailto:${contactEmail}`} class="inline-link">{contactEmail}</a>
          </p>
          <p class="contact-line">
            Website: <a href="https://curvachip.com" class="inline-link">curvachip.com</a>
          </p>
        </div>
        <p>
          We take every privacy question seriously and respond to all emails personally.
        </p>
      </section>

      <!-- APP LINKS -->
      <div class="doc-app-links">
        <a href={appStoreUrl} target="_blank" rel="noopener" class="btn btn-primary">
          ⬇ Download {appName}
        </a>
        <a href={appPageUrl} class="btn btn-ghost">Learn more</a>
        <a href="/privacy" class="btn btn-ghost">All privacy policies</a>
      </div>

    </article>
  </div>
</main>

<!-- ── FOOTER ── -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo-chip" aria-hidden="true">◈</span>
      <span class="logo-text">Curvachip</span>
      <p class="footer-tagline">Crafting exceptional software for Apple platforms.</p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/" class="footer-link">Home</a>
      <a href="/apps" class="footer-link">Apps</a>
      <a href="/privacy" class="footer-link">Privacy</a>
      <a href="/contact" class="footer-link">Contact</a>
      <a href="/about" class="footer-link">About</a>
    </nav>
    <p class="footer-legal">
      Copyright © 2026 Curvachip LLC. All rights reserved.<br />
      <small>Apple is a trademark of Apple Inc. and is not affiliated with Curvachip LLC.</small>
    </p>
    <div class="footer-policy-links">
      <a href="/privacy-policy-curvachip" class="footer-link">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <a href="/terms-and-conditions-curvachip" class="footer-link">Terms of Use</a>
    </div>
  </div>
</footer>

<!-- ── HAMBURGER SCRIPT ── -->
<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('mobile-menu--open');
      hamburger.setAttribute('aria-expanded', String(open));
      mobileMenu.setAttribute('aria-hidden', String(!open));
      hamburger.classList.toggle('hamburger--open', open);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu.classList.contains('mobile-menu--open')) {
        mobileMenu.classList.remove('mobile-menu--open');
        mobileMenu.setAttribute('aria-hidden', 'true');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.classList.remove('hamburger--open');
        hamburger.focus();
      }
    });
  }
</script>

</body>
</html>

<style is:global>
  :root {
    /* ── PALETTE ── */
    --cc-bg:        #080810;
    --cc-surface:   #10101E;
    --cc-border:    #1C1C32;
    --cc-blue:      #5B9CF6;
    --cc-blue-dim:  rgba(91, 156, 246, 0.12);
    --cc-violet:    #A78BFA;
    --cc-green:     #34D399;
    --cc-amber:     #FBBF24;
    --cc-red:       #EF4444;
    --cc-text:      #E8E8F0;
    --cc-muted:     #6A6A88;
    --cc-radius:    12px;
    --cc-max:       1120px;

    /* ── TYPOGRAPHY ── */
    --font-display: 'Outfit', system-ui, sans-serif;
    --font-body:    'DM Sans', system-ui, sans-serif;
    --font-size-base: 1.0625rem;   /* 17px — one step up from 16px */
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--cc-bg); color: var(--cc-text);
    font-family: var(--font-body); font-size: var(--font-size-base);
    line-height: 1.65; -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  strong { font-weight: 600; }
  .container { width: 100%; max-width: var(--cc-max); margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2.5rem); }

  /* ── NAV ── */
  .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid var(--cc-border);
        background: rgba(8, 8, 16, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }
    .nav-inner {
        max-width: var(--cc-max);
        margin-inline: auto;
        padding-inline: clamp(1.25rem, 5vw, 2.5rem);
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
  .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 1.05rem;
        letter-spacing: -0.01em;
    }
  .logo-chip {
      height: 20px;
      width: auto;
      display: block;
  }
  .logo-text {
        font-weight: 600;
    }
  .nav-links { display: flex; gap: 0.25rem; list-style: none; }
  .nav-link { padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.875rem; color: var(--cc-muted); transition: color 0.15s, background 0.15s; }
  .nav-link:hover, .nav-link.active { color: var(--cc-text); background: rgba(255,255,255,0.06); }

  /* ── HAMBURGER ── */
  .hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; border-radius: 6px; }
  .hamburger:focus-visible { outline: 2px solid var(--cc-blue); outline-offset: 2px; }
  .ham-bar { display: block; width: 22px; height: 2px; background: var(--cc-text); border-radius: 2px; transition: transform 0.22s ease, opacity 0.18s ease; transform-origin: center; }
  .hamburger--open .ham-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger--open .ham-bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger--open .ham-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }

  /* ── MOBILE MENU ── */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--cc-border);
    background: rgba(8,8,16,0.97);
  }
  .mobile-menu--open { display: block; }
  .mobile-links { list-style: none; padding: 0.75rem clamp(1.25rem, 5vw, 2.5rem); display: flex; flex-direction: column; gap: 0.25rem; }
  .mobile-link { display: block; padding: 0.7rem 0.75rem; border-radius: 8px; font-size: 1rem; color: var(--cc-muted); transition: color 0.15s, background 0.15s; }
