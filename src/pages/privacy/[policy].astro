---
// src/pages/apps/[policy].astro
// ═══════════════════════════════════════════════════════════════
// DYNAMIC PRIVACY POLICY ROUTE
// ───────────────────────────────────────────────────────────────
// Each entry in getStaticPaths() generates one page at:
//   /apps/<policy slug>
//
// TO ADD A NEW APP:
//   1. Copy the Shadow Task object below in its entirety.
//   2. Change every field — slug, appName, emoji, etc.
//   3. Flip aiProcessing / icloudSync / thirdParty as needed.
//   4. Update the dataItems array to match what that app actually stores.
//   5. Run `astro build` — the new URL appears automatically.
// ═══════════════════════════════════════════════════════════════

// ── TYPE DEFINITIONS ───────────────────────────────────────────
// Keeping these explicit makes every field self-documenting and
// gives you autocomplete in VS Code / Cursor.

import Layout from "../../layouts/Layout.astro";

type StoredLocation = "on-device" | "external" | "none";

interface DataItem {
    category: string; // what kind of data
    purpose: string; // why it is collected / processed
    stored: StoredLocation; // where it ends up
    retained: string; // how long
    sharedWith: string; // "nobody" or an explicit third-party name
}

interface AppPolicy {
    // ── Identity ──
    appName: string; // display name, e.g. "Shadow Task"
    appTagline: string; // short descriptor, e.g. "Focus & Track"
    iconUrl: string; // emoji used on the apps page, e.g. "🌑"

    // ── URLs ──
    appStoreUrl: string; // direct App Store link for this app
    appPageUrl: string; // internal Astro page path, e.g. "/shadow-task"
    canonicalUrl: string; // full public URL of THIS privacy policy page

    // ── Dates / contact ──
    lastUpdated: string; // human-readable, e.g. "June 2025"
    contactEmail: string; // almost always "developer@curvachip.com"

    // ── Feature flags (controls which sections render) ──
    aiProcessing: boolean; // true → shows AI section + amber callout
    icloudSync: boolean; // true → shows iCloud section
    thirdParty: boolean; // true → shows third-party section

    // ── AI details (only needed when aiProcessing = true) ──
    aiProviderName: string; // e.g. "OpenAI", "Google Gemini"
    aiProviderPolicyUrl: string; // link to that provider's privacy policy

    // ── Data table ──
    dataItems: DataItem[];
}

// ── ROUTE DEFINITIONS ──────────────────────────────────────────
export function getStaticPaths() {
    const policies: { params: { policy: string }; props: AppPolicy }[] = [
        // ────────────────────────────────────────────────────────────
        // SHADOW TASK
        // Fully on-device Pomodoro timer. No data leaves the device.
        // ────────────────────────────────────────────────────────────
        {
            params: { policy: "shadow-task" },
            props: {
                appName: "Shadow Task",
                appTagline: "Focus & Track",
                iconUrl: "/shadow-task.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/study-timer-shadow-task/id6737145799?itscg=30200&itsct=apps_box_link&mttnsubad=6737145799",
                appPageUrl: "/shadow-task",
                canonicalUrl: "https://curvachip.com/privacy/shadow-task",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: false,
                icloudSync: false,
                thirdParty: false,

                // Not used (aiProcessing is false) — keep as empty strings
                aiProviderName: "",
                aiProviderPolicyUrl: "",

                dataItems: [
                    {
                        category: "Task names",
                        purpose: "Displaying your tasks in the timer interface",
                        stored: "on-device",
                        retained:
                            "Until you delete the task or uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Timer session data",
                        purpose:
                            "Tracking completed Pomodoro sessions and daily progress",
                        stored: "on-device",
                        retained:
                            "Until you clear history or uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Custom quotes",
                        purpose:
                            "Displaying your personal motivational quotes during focus sessions",
                        stored: "on-device",
                        retained:
                            "Until you delete the quote or uninstall the app",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ────────────────────────────────────────────────────────────
        // TIPZAP
        // Simple tip calculator. No data leaves the device.
        // ────────────────────────────────────────────────────────────
        {
            params: { policy: "tipzap" },
            props: {
                appName: "TipZap",
                appTagline: "Tip Calculator",
                iconUrl: "/tipzap.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/tip-calculator-tipzap/id6743986322?itscg=30200&itsct=apps_box_link&mttnsubad=6743986322",
                appPageUrl: "/tipzap",
                canonicalUrl: "https://curvachip.com/privacy/tipzap",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: false,
                icloudSync: false,
                thirdParty: false,

                // Not used (aiProcessing is false) — keep as empty strings
                aiProviderName: "",
                aiProviderPolicyUrl: "",

                dataItems: [
                    {
                        category: "Tip and split calculations",
                        purpose: "Performing calculations within the app",
                        stored: "on-device",
                        retained:
                            "Not persisted — cleared when you close the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Tip percentage",
                        purpose:
                            "Tracking your preferred tip percentage for calculations",
                        stored: "on-device",
                        retained: "Until you uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Currency preference",
                        purpose:
                            "Displaying amounts in your country's currency as selected in the device settings",
                        stored: "on-device",
                        retained: "Until you uninstall the app",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ────────────────────────────────────────────────────────────
        // STONECLIP
        // AI-powered rock identifier. Uses OpenAI for image processing.
        // ────────────────────────────────────────────────────────────
        {
            params: { policy: "stoneclip" },
            props: {
                appName: "StoneClip",
                appTagline: "AI-powered Rock Identifier",
                iconUrl: "/stoneclip.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/crystal-identifier-stoneclip/id6744538893?itscg=30200&itsct=apps_box_link&mttnsubad=6744538893",
                appPageUrl: "/stoneclip",
                canonicalUrl: "https://curvachip.com/privacy/stoneclip",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: true,
                icloudSync: false,
                thirdParty: true,

                // Use (aiProcessing is true) — populate with actual values
                aiProviderName: "OpenAI",
                aiProviderPolicyUrl:
                    "https://openai.com/policies/privacy-policy",

                dataItems: [
                    {
                        category: "Submitted images and text",
                        purpose:
                            "Identifying rocks and minerals, answering questions, and generating AI responses",
                        stored: "external",
                        retained:
                            "Temporarily by OpenAI for abuse monitoring (typically up to 30 days). Not used to train OpenAI models.",
                        sharedWith: "Cloudflare and OpenAI",
                    },
                    {
                        category: "AI responses",
                        purpose:
                            "Displaying rock identifications and AI-generated explanations",
                        stored: "external",
                        retained:
                            "OpenAI may temporarily retain generated responses for abuse monitoring and security purposes.",
                        sharedWith: "OpenAI",
                    },
                    {
                        category: "Network information",
                        purpose:
                            "Routing requests, security, and abuse prevention",
                        stored: "external",
                        retained:
                            "Processed by Cloudflare to provide routing and security services. Retention is subject to Cloudflare's policies.",
                        sharedWith: "Cloudflare",
                    },
                    {
                        category: "AI chat history",
                        purpose:
                            "Storing previous interactions to provide context for ongoing conversations",
                        stored: "on-device",
                        retained:
                            "Until you clear the chat history or uninstall the app.",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ────────────────────────────────────────────────────────────
        // BUGCLIP
        // AI-powered bug identifier. Uses OpenAI for image processing.
        // ────────────────────────────────────────────────────────────
        {
            params: { policy: "bugclip" },
            props: {
                appName: "BugClip",
                appTagline: "AI-powered Bug Identifier",
                iconUrl: "/bugclip.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/bug-identifier-bugclip-ai/id6745129568?itscg=30200&itsct=apps_box_link&mttnsubad=6745129568",
                appPageUrl: "/bugclip",
                canonicalUrl: "https://curvachip.com/privacy/bugclip",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: true,
                icloudSync: false,
                thirdParty: true,

                // Use (aiProcessing is true) — populate with actual values
                aiProviderName: "OpenAI",
                aiProviderPolicyUrl:
                    "https://openai.com/policies/privacy-policy",

                dataItems: [
                    {
                        category: "Submitted images and text",
                        purpose:
                            "Identifying bugs and insects, answering questions, and generating AI responses",
                        stored: "external",
                        retained:
                            "Temporarily by OpenAI for abuse monitoring (typically up to 30 days). Not used to train OpenAI models.",
                        sharedWith: "Cloudflare and OpenAI",
                    },
                    {
                        category: "AI responses",
                        purpose:
                            "Displaying bug identifications and AI-generated explanations",
                        stored: "external",
                        retained:
                            "OpenAI may temporarily retain generated responses for abuse monitoring and security purposes.",
                        sharedWith: "OpenAI",
                    },
                    {
                        category: "Network information",
                        purpose:
                            "Routing requests, security, and abuse prevention",
                        stored: "external",
                        retained:
                            "Processed by Cloudflare to provide routing and security services. Retention is subject to Cloudflare's policies.",
                        sharedWith: "Cloudflare",
                    },
                    {
                        category: "AI chat history",
                        purpose:
                            "Storing previous interactions to provide context for ongoing conversations",
                        stored: "on-device",
                        retained:
                            "Until you clear the chat history or uninstall the app.",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ────────────────────────────────────────────────────────────
        // PLANTCLIP
        // AI-powered plant identifier. Uses OpenAI for image processing.
        // ────────────────────────────────────────────────────────────
        {
            params: { policy: "plantclip" },
            props: {
                appName: "PlantClip",
                appTagline: "AI-powered Plant Identifier",
                iconUrl: "/plantclip.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/identify-plants-plantclip/id6745438705?itscg=30200&itsct=apps_box_link&mttnsubad=6745438705",
                appPageUrl: "/plantclip",
                canonicalUrl: "https://curvachip.com/privacy/plantclip",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: true,
                icloudSync: false,
                thirdParty: true,

                // Use (aiProcessing is true) — populate with actual values
                aiProviderName: "OpenAI",
                aiProviderPolicyUrl:
                    "https://openai.com/policies/privacy-policy",

                dataItems: [
                    {
                        category: "Submitted images and text",
                        purpose:
                            "Identifying plants, answering questions, and generating AI responses",
                        stored: "external",
                        retained:
                            "Temporarily by OpenAI for abuse monitoring (typically up to 30 days). Not used to train OpenAI models.",
                        sharedWith: "Cloudflare and OpenAI",
                    },
                    {
                        category: "AI responses",
                        purpose:
                            "Displaying plant identifications and AI-generated explanations",
                        stored: "external",
                        retained:
                            "OpenAI may temporarily retain generated responses for abuse monitoring and security purposes.",
                        sharedWith: "OpenAI",
                    },
                    {
                        category: "Network information",
                        purpose:
                            "Routing requests, security, and abuse prevention",
                        stored: "external",
                        retained:
                            "Processed by Cloudflare to provide routing and security services. Retention is subject to Cloudflare's policies.",
                        sharedWith: "Cloudflare",
                    },
                    {
                        category: "Precise location",
                        purpose:
                            "Providing the AI with your location to improve the accuracy of plant identification and region-specific information",
                        stored: "external",
                        retained:
                            "Only when you choose to share your location. OpenAI may temporarily retain the transmitted location for abuse monitoring and security purposes. API data is not used to train OpenAI models.",
                        sharedWith: "Cloudflare and OpenAI",
                    },
                    {
                        category: "AI chat history",
                        purpose:
                            "Storing previous interactions to provide context for ongoing conversations",
                        stored: "on-device",
                        retained:
                            "Until you clear the chat history or uninstall the app.",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ───────────────────────────────────────────────────────────
        // GROCERY WIZ
        // Smart shopping assistant. Fully on-device.
        // ───────────────────────────────────────────────────────────
        {
            params: { policy: "grocery-wiz" },
            props: {
                appName: "Grocery Wiz",
                appTagline: "Shopping List",
                iconUrl: "/grocery-wiz.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/shopping-list-grocery-wiz/id6746955108?itscg=30200&itsct=apps_box_link&mttnsubad=6746955108",
                appPageUrl: "/grocery-wiz",
                canonicalUrl: "https://curvachip.com/privacy/grocery-wiz",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: false,
                icloudSync: false,
                thirdParty: false,

                // Not used (aiProcessing is false) — keep as empty strings
                aiProviderName: "",
                aiProviderPolicyUrl: "",

                dataItems: [
                    {
                        category: "Grocery list items",
                        purpose: "Storing your shopping list and item details",
                        stored: "on-device",
                        retained:
                            "Until you delete the list or uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "List categories and preferences",
                        purpose:
                            "Tracking your preferred shopping categories and preferences",
                        stored: "on-device",
                        retained: "Until you uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Shopping history",
                        purpose:
                            "Keeping a record of your past shopping trips for reference",
                        stored: "on-device",
                        retained:
                            "Until you clear the history or uninstall the app",
                        sharedWith: "nobody",
                    },
                ],
            },
        },

        // ───────────────────────────────────────────────────────────
        // TALLY SNAP
        // Quick and easy tally counter. Fully on-device.
        // ───────────────────────────────────────────────────────────
        {
            params: { policy: "tally-snap" },
            props: {
                appName: "Tally Snap",
                appTagline: "Click Counter",
                iconUrl: "/tally-snap.png",

                appStoreUrl:
                    "https://apps.apple.com/us/app/click-counter-tally-snap/id6746059766?itscg=30200&itsct=apps_box_link&mttnsubad=6746059766",
                appPageUrl: "/tally-snap",
                canonicalUrl: "https://curvachip.com/privacy/tally-snap",

                lastUpdated: "July 2026",
                contactEmail: "developer@curvachip.com",

                aiProcessing: false,
                icloudSync: false,
                thirdParty: false,

                // Not used (aiProcessing is false) — keep as empty strings
                aiProviderName: "",
                aiProviderPolicyUrl: "",

                dataItems: [
                    {
                        category: "Tally counts",
                        purpose: "Storing your tally counts and labels",
                        stored: "on-device",
                        retained:
                            "Until you delete the counts or uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Color themes and sounds",
                        purpose:
                            "Maintaining your preferred color themes and sound settings",
                        stored: "on-device",
                        retained: "Until you uninstall the app",
                        sharedWith: "nobody",
                    },
                    {
                        category: "Counting increments",
                        purpose:
                            "Tracking your preferred counting increments for quick tallies",
                        stored: "on-device",
                        retained:
                            "Until you clear the history or uninstall the app",
                        sharedWith: "nobody",
                    },
                ],
            },
        },
    ];

    return policies;
}

// ── DESTRUCTURE PROPS ──────────────────────────────────────────
// Astro passes the matching props object for the current route.
const {
    appName,
    appTagline,
    iconUrl,
    appStoreUrl,
    appPageUrl,
    canonicalUrl,
    lastUpdated,
    contactEmail,
    aiProcessing,
    icloudSync,
    thirdParty,
    aiProviderName,
    aiProviderPolicyUrl,
    dataItems,
} = Astro.props as AppPolicy;

// Derived meta — built from props so they're always in sync
const title = `Privacy Policy — ${appName} | Curvachip`;
const description = `Privacy policy for ${appName} by Curvachip LLC. Exactly what data is collected, how it is used, and your rights as a user.`;

let section = 1;

const overviewNum = section++;
const collectedNum = section++;
const usageNum = section++;

const aiNum = aiProcessing ? section++ : null;
const icloudNum = icloudSync ? section++ : null;
const thirdPartyNum = thirdParty ? section++ : null;

const retentionNum = section++;
const rightsNum = section++;
const childrenNum = section++;
const changesNum = section++;
const contactNum = section++;
---

<Layout
    title={title}
    description={description}
    activeNav="privacy"
    canonicalUrl={canonicalUrl}
>
    <!-- ── HEADER ── -->
    <header class="doc-hero">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="container doc-hero-inner">
            <a href="/apps" class="back-link">← Back to Apps</a>
            <div class="app-ident">
                <a href={appStoreUrl} target="_blank" rel="noopener noreferrer">
                    <img src={iconUrl} alt={appName} width="64" height="64" />
                </a>
                <div>
                    <p class="app-ident-tagline">{appTagline}</p>
                    <h1 class="app-ident-name">{appName}</h1>
                </div>
            </div>
            <h2 class="doc-title">Privacy Policy</h2>
            <p class="doc-meta">
                Curvachip LLC · Last updated: {lastUpdated}
            </p>
            <p class="doc-intro">
                This policy explains what data {appName} collects, why it collects
                it, and exactly what happens to it. There is no fine print. If anything
                here is unclear, email us and we will explain it.
            </p>
        </div>
    </header>

    <!-- ── BODY ── -->
    <main>
        <div class="container doc-layout">
            <!-- TABLE OF CONTENTS -->
            <nav class="toc" aria-label="Table of contents">
                <p class="toc-title">On this page</p>
                <ol class="toc-list">
                    <li>
                        <a href="#overview" class="toc-link">{overviewNum}. Overview</a>
                    </li>
                    <li>
                        <a href="#data-collected" class="toc-link"
                            >{collectedNum}. What we collect</a
                        >
                    </li>
                    <li>
                        <a href="#data-use" class="toc-link">{usageNum}. How we handle your data</a
                        >
                    </li>
                    {
                        aiProcessing && (
                            <li>
                                <a href="#ai" class="toc-link">
                                    {aiNum}. AI processing
                                </a>
                            </li>
                        )
                    }
                    {
                        icloudSync && (
                            <li>
                                <a href="#icloud" class="toc-link">
                                    {icloudNum}. iCloud sync
                                </a>
                            </li>
                        )
                    }
                    {
                        thirdParty && (
                            <li>
                                <a href="#third-party" class="toc-link">
                                    {thirdPartyNum}. Third parties
                                </a>
                            </li>
                        )
                    }
                    <li>
                        <a href="#retention" class="toc-link"
                            >{retentionNum}. Data retention</a
                        >
                    </li>
                    <li>
                        <a href="#rights" class="toc-link">{rightsNum}. Your rights</a>
                    </li>
                    <li>
                        <a href="#children" class="toc-link">{childrenNum}. Children</a>
                    </li>
                    <li>
                        <a href="#changes" class="toc-link">{changesNum}. Changes</a>
                    </li>
                    <li>
                        <a href="#contact" class="toc-link">{contactNum}. Contact</a>
                    </li>
                </ol>
            </nav>

            <!-- DOCUMENT -->
            <article class="doc-body">
                <!-- 1. OVERVIEW -->
                <section id="overview" class="doc-section">
                    <h2 class="doc-h2">{overviewNum}. Overview</h2>
                    <p>
                        {appName} is published by Curvachip LLC, a single-person software
                        company. We are committed to limiting the data we collect
                        as much as possible, processing data on-device wherever feasible,
                        and being completely transparent about anything we do collect.
                    </p>
                    {
                        !aiProcessing && !icloudSync && !thirdParty && (
                            <div class="callout callout--green">
                                <span class="callout-icon" aria-hidden="true">
                                    ✓
                                </span>
                                <div>
                                    <strong>
                                        This app is fully on-device.
                                    </strong>{" "}
                                    {appName} does not send any data to
                                    Curvachip or any third party. Everything you
                                    do in the app stays on your device.
                                </div>
                            </div>
                        )
                    }
                    {
                        (aiProcessing || icloudSync || thirdParty) && (
                            <div class="callout callout--blue">
                                <span class="callout-icon" aria-hidden="true">
                                    ◈
                                </span>
                                <div>
                                    <strong>
                                        Some data leaves your device.
                                    </strong>{" "}
                                    The sections below explain exactly what,
                                    why, and where it goes.
                                </div>
                            </div>
                        )
                    }
                </section>

                <!-- 2. DATA COLLECTED -->
                <section id="data-collected" class="doc-section">
                    <h2 class="doc-h2">{collectedNum}. What we collect</h2>
                    <p>
                        The table below is a complete record of every category
                        of data that {appName}
                        collects or processes. If a category is not listed here, we
                        do not collect it.
                    </p>
                    <div
                        class="data-table-wrapper"
                        role="region"
                        aria-label="Data collection table"
                        tabindex="0"
                    >
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th scope="col">Data category</th>
                                    <th scope="col">Purpose</th>
                                    <th scope="col">Stored</th>
                                    <th scope="col">Retained</th>
                                    <th scope="col">Shared with</th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    dataItems.map((row) => (
                                        <tr>
                                            <td>{row.category}</td>
                                            <td>{row.purpose}</td>
                                            <td>
                                                <span
                                                    class={`badge badge--${
                                                        row.stored ===
                                                        "on-device"
                                                            ? "green"
                                                            : row.stored ===
                                                                "external"
                                                              ? "amber"
                                                              : "muted"
                                                    }`}
                                                >
                                                    {row.stored}
                                                </span>
                                            </td>
                                            <td>{row.retained}</td>
                                            <td>{row.sharedWith}</td>
                                        </tr>
                                    ))
                                }
                                {
                                    dataItems.length === 0 && (
                                        <tr>
                                            <td colspan="5" class="table-empty">
                                                No data is collected.
                                            </td>
                                        </tr>
                                    )
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="table-note">
                        We never collect: your name, email address, phone
                        number, location, contacts, photos (beyond what you
                        explicitly submit to a feature), or any device
                        identifier that could be used to track you across apps.
                    </p>
                </section>

                <!-- 3. HOW WE USE IT -->
                <section id="data-use" class="doc-section">
                    <h2 class="doc-h2">{usageNum}. How we handle your data</h2>
                    <p>
                        Any data processed by {appName} is used only to provide the
                        features you choose to use. We do not use your data for unrelated
                        purposes.
                    </p>

                    <p>Specifically, we never:</p>
                    <ul class="policy-list">
                        <li>Sell your data to any party</li>
                        <li>Use your data for advertising</li>
                        <li>Build a profile of you across apps or sessions</li>
                        <li>
                            Share your data with anyone not listed in the table
                            above
                        </li>
                        <li>
                            Retain data beyond the period necessary for the
                            feature it supports
                        </li>
                    </ul>
                </section>

                <!-- 4. AI PROCESSING — only renders when aiProcessing = true -->
                {
                    aiProcessing && (
                        <section id="ai" class="doc-section">
                            <h2 class="doc-h2">{aiNum}. AI processing</h2>
                            <div class="callout callout--amber">
                                <span class="callout-icon" aria-hidden="true">
                                    ⚠
                                </span>
                                <div>
                                    <strong>
                                        Some data is processed by an external AI
                                        service.
                                    </strong>{" "}
                                    When you use the identification feature, the
                                    image or text you submit is sent to a
                                    third-party AI provider. It is not stored by
                                    Curvachip, but it is processed outside your
                                    device.
                                </div>
                            </div>
                            <p>
                                {appName} uses <strong>{aiProviderName}</strong>{" "}
                                to process identification requests. The data
                                sent consists only of the image or text you
                                explicitly submit by pressing the identification
                                button. This data is:
                            </p>
                            <ul class="policy-list">
                                <li>
                                    Transmitted over an encrypted HTTPS
                                    connection
                                </li>
                                <li>
                                    Processed by {aiProviderName} under their
                                    own privacy policy:{" "}
                                    <a
                                        href={aiProviderPolicyUrl}
                                        target="_blank"
                                        rel="noopener"
                                        class="inline-link"
                                    >
                                        {aiProviderPolicyUrl}
                                    </a>
                                </li>
                                <li>
                                    Not stored by Curvachip after the response
                                    is returned
                                </li>
                                <li>
                                    Not used to train Curvachip's own models (we
                                    don't have any)
                                </li>
                            </ul>
                            <p>
                                We recommend reviewing {aiProviderName}'s
                                privacy policy if you have concerns about how
                                they handle submitted data on their end.
                            </p>
                        </section>
                    )
                }

                <!-- 5. ICLOUD SYNC — only renders when icloudSync = true -->
                {
                    icloudSync && (
                        <section id="icloud" class="doc-section">
                            <h2 class="doc-h2">{icloudNum}. iCloud sync</h2>
                            <p>
                                {appName} uses Apple's CloudKit framework to
                                sync your data across your devices via iCloud.
                                This means your data is stored in your personal
                                iCloud account — Curvachip cannot access it.
                                Apple's iCloud is governed by{" "}
                                <a
                                    href="https://www.apple.com/legal/privacy/"
                                    target="_blank"
                                    rel="noopener"
                                    class="inline-link"
                                >
                                    Apple's Privacy Policy
                                </a>
                                .
                            </p>
                            <p>
                                You can disable iCloud sync for {appName} at any
                                time in
                                <strong>
                                    {" "}
                                    Settings → [Your Name] → iCloud
                                </strong>{" "}
                                on your device. Disabling sync does not delete
                                data already stored locally on your device.
                            </p>
                        </section>
                    )
                }

                <!-- 6. THIRD PARTIES — only renders when thirdParty = true -->
                {
                    thirdParty && (
                        <section id="third-party" class="doc-section">
                            <h2 class="doc-h2">{thirdPartyNum}. Third-party services</h2>
                            <p>
                                {appName} uses the following third-party
                                services. Each link goes to that service's own
                                privacy policy:
                            </p>
                            <ul class="policy-list">
                                {/* Add specific third-party entries here when thirdParty = true */}
                                <li>
                                    See the data table in section 2 for the
                                    complete list of services.
                                </li>
                            </ul>
                            <p>
                                Curvachip selects third-party services carefully
                                and only includes those that are necessary for a
                                specific feature. We do not use advertising
                                SDKs.
                            </p>
                        </section>
                    )
                }

                <!-- 7. RETENTION -->
                <section id="retention" class="doc-section">
                    <h2 class="doc-h2">{retentionNum}. Data retention</h2>
                    <p>
                        On-device data is retained until you delete the app or
                        manually clear it within the app's settings. Curvachip
                        holds no copies of on-device data and cannot recover it
                        if you uninstall the app.
                    </p>
                    {
                        aiProcessing && (
                            <p>
                                Data submitted to the AI identification feature
                                is processed in real time and is not retained by
                                Curvachip after the response is received.
                                Retention by {aiProviderName} is governed by
                                their own privacy policy.
                            </p>
                        )
                    }
                </section>

                <!-- 8. YOUR RIGHTS -->
                <section id="rights" class="doc-section">
                    <h2 class="doc-h2">{rightsNum}. Your rights</h2>
                    <p>
                        Depending on where you live, you may have rights under
                        applicable privacy law (including GDPR, CCPA, or
                        equivalent legislation). Because {appName} collects minimal
                        data, most of these rights are satisfied automatically:
                    </p>
                    <ul class="policy-list">
                        <li>
                            <strong>Access:</strong> On-device data is stored only
                            on your device — you have direct access to it at all times.
                        </li>
                        <li>
                            <strong>Deletion:</strong> Delete the app to remove all
                            on-device data. For any data held by a third party, contact
                            that party directly.
                        </li>
                        <li>
                            <strong>Portability:</strong> On-device data is not locked
                            in a proprietary format inaccessible to you.
                        </li>
                        <li>
                            <strong>Objection / opt-out:</strong> You can stop using
                            any feature that processes data externally. AI features
                            can be ignored without losing core functionality.
                        </li>
                    </ul>
                    <p>
                        To exercise any right or ask a question about your data,
                        email us at{" "}
                        <a href={`mailto:${contactEmail}`} class="inline-link"
                            >{contactEmail}</a
                        >. We will respond within 30 days.
                    </p>
                </section>

                <!-- 9. CHILDREN -->
                <section id="children" class="doc-section">
                    <h2 class="doc-h2">{childrenNum}. Children</h2>
                    <p>
                        {appName} is not directed at children under 13. We do not
                        knowingly collect any information from users under 13. If
                        you believe a child has submitted data through this app, please
                        contact us immediately at{" "}
                        <a href={`mailto:${contactEmail}`} class="inline-link"
                            >{contactEmail}</a
                        > and we will address it promptly.
                    </p>
                </section>

                <!-- 10. CHANGES -->
                <section id="changes" class="doc-section">
                    <h2 class="doc-h2">{changesNum}. Changes to this policy</h2>
                    <p>
                        If this policy changes in a material way — for example,
                        if a new feature requires collecting data that was not
                        collected before — the revised policy will be published
                        on this page with an updated date at the top. Continued
                        use of {appName} after such changes constitutes acceptance
                        of the revised policy.
                    </p>
                    <p>
                        We will not silently expand data collection. Any
                        material change will be communicated via an App Store
                        update note.
                    </p>
                </section>

                <!-- 11. CONTACT -->
                <section id="contact" class="doc-section">
                    <h2 class="doc-h2">{contactNum}. Contact</h2>
                    <p>
                        Questions, concerns, or requests regarding this policy
                        should be sent to:
                    </p>
                    <div class="contact-block">
                        <p class="contact-line">
                            <strong>Curvachip LLC</strong>
                        </p>
                        <p class="contact-line">
                            Email:{" "}
                            <a
                                href={`mailto:${contactEmail}`}
                                class="inline-link">{contactEmail}</a
                            >
                        </p>
                        <p class="contact-line">
                            Website:{" "}
                            <a href="https://curvachip.com" class="inline-link"
                                >curvachip.com</a
                            >
                        </p>
                    </div>
                    <p>
                        We take every privacy question seriously and respond to
                        all emails personally.
                    </p>
                </section>

                <!-- BOTTOM ACTIONS -->
                <div class="doc-app-links">
                    <a
                        href={appStoreUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <img
                            src="/appblack.svg"
                            alt={appName + " on the App Store"}
                            height="44"
                        />
                    </a>
                    <a href={appPageUrl} class="btn btn-ghost">Learn more</a>
                    <a href="/apps" class="btn btn-ghost">← All apps</a>
                </div>
            </article>
        </div>
    </main>
</Layout>

