---
// src/pages/privacy-policy-curvachip.astro
// Website-level privacy policy for curvachip.com
// Not an app policy — covers the website itself.

import { Info, X } from 'lucide-astro';
import Layout from '../../layouts/Layout.astro';

const lastUpdated   = "July 2026";
const contactEmail  = "developer@curvachip.com";
const canonicalUrl  = "https://curvachip.com/privacy/website";

const notCollected = [
  {
    data: "Your name, email address, or any other contact information"
  },
  {
    data: "User accounts, passwords, or profile information"
  },
  {
    data: "Cookies or other persistent tracking identifiers"
  },
  {
    data: "Analytics about which pages you visit or how long you spend on them"
  },
  {
    data: "Advertising identifiers or marketing profiles"
  },
  {
    data: "Payment or financial information of any kind"
  },
  {
    data: "Any identifiers used to recognise or track you across browsing sessions"
  },
]
---

<Layout
  title="Website Privacy Policy | Curvachip"
  description="The privacy policy for curvachip.com. This website collects no personal data, uses no cookies, and has no tracking of any kind."
  activeNav="privacy"
  canonicalUrl={canonicalUrl}
>

  <!-- ── HEADER ── -->
  <header class="doc-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container doc-hero-inner">
      <div>
      <a href="/" class="back-link">← Back to Home</a> <div class="doc-badge">Legal</div>
      </div>
      <h1 class="doc-title">Privacy Policy</h1>
      <p class="doc-meta">Curvachip LLC · curvachip.com · Last updated: {lastUpdated}</p>
      <p class="doc-intro">
        This policy covers the curvachip.com website only — not the individual apps
        distributed by Curvachip. Each app has its own privacy policy linked from 
        the <a href="/apps" class="inline-link">Apps</a> page. We do not collect, store, 
        or process personal information through this website except as described below.
      </p>
    </div>
  </header>

  <!-- ── BODY ── -->
  <main>
    <div class="container doc-layout">

      <!-- TABLE OF CONTENTS -->
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-title">On this page</p>
        <ol class="toc-list">
          <li><a href="#overview"     class="toc-link">1. Overview</a></li>
          <li><a href="#no-data"      class="toc-link">2. Data we do not collect</a></li>
          <li><a href="#email"        class="toc-link">3. Contact form</a></li>
          <li><a href="#cookies"      class="toc-link">4. Cookies & tracking</a></li>
          <li><a href="#third-party"  class="toc-link">5. Third-party services</a></li>
          <li><a href="#hosting"      class="toc-link">6. Hosting</a></li>
          <li><a href="#children"     class="toc-link">7. Children</a></li>
          <li><a href="#changes"      class="toc-link">8. Changes</a></li>
          <li><a href="#contact"      class="toc-link">9. Contact</a></li>
        </ol>
      </nav>

      <!-- DOCUMENT -->
      <article class="doc-body">

        <!-- 1. OVERVIEW -->
        <section id="overview" class="doc-section">
          <h2 class="doc-h2">1. Overview</h2>
          <p>
            Curvachip LLC operates curvachip.com as a static informational website.
            Limited technical information is processed by our hosting provider (Cloudflare) 
            as required to deliver website content securely. Curvachip does not use this information 
            for analytics or visitor tracking. We have deliberately built this website 
            to be as privacy-respecting as possible.
          </p>
          <div class="callout callout--green">
            <span class="callout-icon" aria-hidden="true">✓</span>
            <div>
              <strong>This website guards your privacy.</strong> You can browse every
              page on curvachip.com without any information about you being recorded,
              stored, or shared by Curvachip except as necessary to host this site.
            </div>
          </div>
        </section>

        <!-- 2. DATA WE DO NOT COLLECT -->
        <section id="no-data" class="doc-section">
          <h2 class="doc-h2">2. Data we do not collect</h2>
          <p>
            Curvachip does not intentionally collect, store, or process personal 
            information when you browse this website. Specifically, we do not collect:
          </p>
          <ul class="policy-list">
            {
              notCollected.map((p) => (
                <li>
                  <span class="denied-icon" aria-hidden="true">
                    <X />
                  </span>
                  {p.data}
                </li>
              ))
            }
          </ul>
          <p>
            There is no user account system on this website. There is nothing to sign
            up for or log into.
          </p>
        </section>

        <!-- 3. CONTACT FORM -->
        <section id="email" class="doc-section">
          <h2 class="doc-h2">3. Contact form</h2>
          <p>
            The Contact page includes a message form. When you press the Send button,
            your device opens your default mail client with the form fields pre-filled.
            The message is sent directly from your own email account to
            <a href={`mailto:${contactEmail}`} class="inline-link"> {contactEmail}</a>.
          </p>
          <div class="callout callout--blue">
            <span class="callout-icon" aria-hidden="true"><Info size={18}/></span>
            <div>
              <strong>No data passes through curvachip.com.</strong> The form does not
              submit to a server. Curvachip never sees your message until it arrives in
              the inbox as a normal email. Your email provider's privacy policy governs
              the transmission.
            </div>
          </div>
          <p>
            Emails sent to Curvachip are read and responded to by the developer personally.
            They are not shared with third parties and are retained only as long as
            necessary to address your enquiry.
          </p>
        </section>

        <!-- 4. COOKIES AND TRACKING -->
        <section id="cookies" class="doc-section">
          <h2 class="doc-h2">4. Cookies &amp; tracking</h2>
          <p>
            This website sets no cookies — not first-party, not third-party, not session
            cookies, not persistent cookies. There is no cookie banner because there is
            nothing to consent to.
          </p>
          <p>
            We use no analytics platform (Google Analytics, Plausible, Fathom, or otherwise),
            no advertising pixels, no heatmap tools, no A/B testing frameworks, and no
            social media tracking scripts of any kind.
          </p>
        </section>

        <!-- 5. THIRD-PARTY SERVICES -->
        <section id="third-party" class="doc-section">
          <h2 class="doc-h2">5. Third-party services</h2>
          <p>
            All fonts, icons, stylesheets, and other website assets are served directly from 
            curvachip.com. Your browser does not contact Google Fonts or any other 
            external font or icon provider when loading this website.
          </p>
          <p>
            This website does not load third-party analytics scripts, advertising scripts, 
            embedded videos, social media widgets, or external comment systems.
          </p>
          <p>
            This website contains links to third-party websites and services, including the 
            Apple App Store, GitHub, LinkedIn, and other platforms. If you choose to visit 
            those websites, your interaction with them is governed by their own privacy 
            policies rather than this one.
          </p>
          <p>
            Some App Store links include Apple's standard affiliate attribution parameters 
            that identify curvachip.com as the referring website. These parameters are 
            identical for all visitors and do not uniquely identify individual users.
          </p>
        </section>

        <!-- 6. HOSTING -->
        <section id="hosting" class="doc-section">
          <h2 class="doc-h2">6. Hosting</h2>
          <p>
            This website is hosted on Cloudflare Pages. To deliver website content securely
            and efficiently, Cloudflare necessarily processes limited technical information 
            associated with each request, including your IP address, HTTP headers, requested 
            URL, and connection metadata.
          </p>
          <p>
            Cloudflare uses this information to provide content delivery, caching, network 
            security, and abuse prevention. Curvachip does not use this information for 
            analytics, visitor profiling, or advertising, and does not intentionally 
            retain or analyze request logs.
          </p>
          <p>
            <!-- ← UPDATE: insert your hosting provider name and link if you want to be explicit -->
            The hosting provider's own privacy policy governs any infrastructure-level
            data handling. You can learn more by 
            visiting <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener" class="inline-link">Cloudflare's Privacy Policy</a>.
          </p>
        </section>

        <!-- 7. CHILDREN -->
        <section id="children" class="doc-section">
          <h2 class="doc-h2">7. Children</h2>
          <p>
            This website is not directed specifically at children under 13. Because we do not 
            intentionally collect personal information from visitors, there is generally no 
            personal information for us to remove. If you have any concerns, contact us 
            at <a href={`mailto:${contactEmail}`} class="inline-link">{contactEmail}</a>.
          </p>
        </section>

        <!-- 8. CHANGES -->
        <section id="changes" class="doc-section">
          <h2 class="doc-h2">8. Changes to this policy</h2>
          <p>
            If the website ever changes in a way that affects privacy — for example, if
            an analytics tool or contact form backend were added — this policy will be
            updated before that change goes live, with a revised date at the top.
          </p>
          <p>
            Our intent is to keep this website as data-free as it is today. Any change
            that introduces data collection would be clearly disclosed here.
          </p>
        </section>

        <!-- 9. CONTACT -->
        <section id="contact" class="doc-section">
          <h2 class="doc-h2">9. Contact</h2>
          <p>Questions about this policy should be directed to:</p>
          <div class="contact-block">
            <p class="contact-line"><strong>Curvachip LLC</strong></p>
            <p class="contact-line">
              Email: <a href={`mailto:${contactEmail}`} class="inline-link">{contactEmail}</a>
            </p>
            <p class="contact-line">
              Website: <a href="https://curvachip.com" class="inline-link">curvachip.com</a>
            </p>
          </div>
        </section>

        <!-- BOTTOM ACTIONS -->
        <div class="doc-app-links">
          <a href="/apps"    class="btn btn-primary">View our apps</a>
          <a href="/contact" class="btn btn-ghost">Contact us</a>
          <a href="/privacy/terms-of-use" class="btn btn-ghost">Terms of Use →</a>
        </div>

      </article>
    </div>
  </main>

</Layout>

<style>
  /* ── DOC HERO ── */
  .doc-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 8vw, 6rem) 0 clamp(2.5rem, 6vw, 4.5rem);
    border-bottom: 1px solid var(--cc-border);
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 80% at 20% 50%,
      rgba(0, 102, 204, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .doc-hero-inner { position: relative; max-width: 680px; }
  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--cc-muted);
    margin-bottom: 1.75rem;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--cc-blue); }
  .doc-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cc-blue);
    margin-bottom: 1rem;
  }
  .doc-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }
  .doc-meta  { font-size: 0.8rem; color: var(--cc-muted); margin-bottom: 1.25rem; }
  .doc-intro { font-size: 1rem; color: var(--cc-muted); line-height: 1.8; max-width: 580px; }

  /* ── DOC LAYOUT ── */
  .doc-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    padding-block: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }
  @media (max-width: 800px) { .doc-layout { grid-template-columns: 1fr; } }

  /* ── TOC ── */
  .toc { position: sticky; top: 80px; }
  @media (max-width: 800px) {
    .toc {
      position: static;
      background: var(--cc-surface);
      border: 1px solid var(--cc-border);
      border-radius: var(--cc-radius);
      padding: 1.25rem;
    }
  }
  .toc-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cc-muted);
    margin-bottom: 0.75rem;
  }
  .toc-list { list-style: none; display: flex; flex-direction: column; gap: 0.15rem; }
  @media (max-width: 800px) { .toc-list { flex-direction: row; flex-wrap: wrap; gap: 0.4rem; } }
  .toc-link {
    font-size: 0.82rem;
    color: var(--cc-muted);
    padding: 0.3rem 0.5rem;
    border-radius: 5px;
    display: block;
    transition: color 0.15s, background 0.15s;
  }
  .toc-link:hover { color: var(--cc-text); background: rgba(0,0,0,0.04); }

  /* ── DOC BODY ── */
  .doc-body { min-width: 0; }
  .doc-section { margin-bottom: 3rem; }
  .doc-h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 1rem;
    color: var(--cc-text);
  }
  .doc-section p {
    font-size: 0.95rem;
    color: var(--cc-muted);
    line-height: 1.8;
    margin-bottom: 0.85rem;
  }
  .doc-section p:last-child { margin-bottom: 0; }

  /* ── CALLOUTS ── */
  .callout {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0;
  }
  .callout-icon { font-size: 1rem; flex-shrink: 0; margin-top: 0.1rem; }
  .callout div  { font-size: 0.875rem; color: var(--cc-muted); line-height: 1.65; }
  .callout div strong { color: var(--cc-text); }
  .callout--green { background: rgba(52,211,153,0.07); border: 1px solid rgba(52,211,153,0.2); }
  .callout--green .callout-icon { color: var(--cc-green); }
  .callout--blue  { background: rgba(0,102,204,0.06);  border: 1px solid rgba(0,102,204,0.15); }
  .callout--blue  .callout-icon { color: var(--cc-blue); }

  /* ── POLICY LIST ── */
  .policy-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1rem 0;
  }
  .policy-list li {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--cc-muted);
    line-height: 1.65;
  }
  .denied-icon {
    display: inline-flex;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
    color: brown;
  }

  /* ── CONTACT BLOCK ── */
  .contact-block {
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 1.25rem 0;
  }
  .contact-line { font-size: 0.9rem; color: var(--cc-muted); line-height: 1.8; }
  .contact-line strong { color: var(--cc-text); }

  /* ── BOTTOM ACTIONS ── */
  .doc-app-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 2.5rem;
    border-top: 1px solid var(--cc-border);
    margin-top: 3rem;
  }
</style>