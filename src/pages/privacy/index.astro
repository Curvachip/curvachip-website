---
// src/pages/privacy/index.astro
// ═══════════════════════════════════════════════════════════════
// PRIVACY HUB
// ───────────────────────────────────────────────────────────────
// Routing note:
//   This file lives at src/pages/privacy/index.astro → /privacy
//   The existing article moves to:
//     src/pages/privacy/blog/ai-chatbots.astro → /privacy/blog/ai-chatbots
//   Any future blog post is added as a new file in privacy/blog/
//
// PURPOSE:
//   A public-facing overview of Curvachip's privacy posture.
//   Not a legal document — those are the Privacy Policy and T&C.
//   This page answers the human question: "Can I trust this company
//   with my data?" The answer should be obvious before they scroll.
// ═══════════════════════════════════════════════════════════════

import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";

import { Database, MonitorCheck, Megaphone, CircleSlash2, MessageSquareLock, Scroll, NotepadText, MonitorSmartphone, Bot } from "lucide-astro";

import { Image } from "astro:assets";

// ── BLOG POSTS ─────────────────────────────────────────────────
// Add new entries here as you publish more articles.
const blogPosts = [
    {
        slug: "/privacy/blog/ai-chatbots",
        emoji: Bot,
        tag: "AI & Data",
        title: "What You Share with AI Chatbots Stays There",
        excerpt:
            "AI assistants are genuinely useful — but the moment you type something sensitive into one, you've handed it to a server you don't control. Here's what that means and what to do about it.",
        date: "July 2026",
        featured: true,
    },
    // Add future posts here:
    // {
    //   slug:     "/privacy/blog/your-slug",
    //   emoji:    "🔒",
    //   tag:      "Privacy Tips",
    //   title:    "Your Post Title",
    //   excerpt:  "A short excerpt…",
    //   date:     "Month YYYY",
    //   featured: false,
    // },
];

// ── APP PRIVACY CARDS ──────────────────────────────────────────
const appCards = [
    {
        name: "Shadow Task",
        iconUrl: "/shadow-task.png",
        label: "Data Not Collected",
        color: "green",
        href: "/privacy/shadow-task",
    },
    {
        name: "TipZap",
        iconUrl: "/tipzap.png",
        label: "Data Not Collected",
        color: "green",
        href: "/privacy/tipzap",
    },
    {
        name: "StoneClip",
        iconUrl: "/stoneclip.png",
        label: "Data Not Linked to You",
        color: "blue",
        href: "/privacy/stoneclip",
    },
    {
        name: "BugClip",
        iconUrl: "/bugclip.png",
        label: "Data Not Linked to You",
        color: "blue",
        href: "/privacy/bugclip",
    },
    {
        name: "PlantClip",
        iconUrl: "/plantclip.png",
        label: "Data Not Linked to You",
        color: "blue",
        href: "/privacy/plantclip",
    },
    {
        name: "Grocery Wiz",
        iconUrl: "/grocery-wiz.png",
        label: "Data Not Collected",
        color: "green",
        href: "/privacy/grocery-wiz",
    },
    {
        name: "Tally Snap",
        iconUrl: "/tally-snap.png",
        label: "Data Not Collected",
        color: "green",
        href: "/privacy/tally-snap",
    },
];

// ── PRINCIPLES ─────────────────────────────────────────────────
const principles = [
    {
        icon: Database,
        title: "Collect only what is necessary",
        body: "Every data point we process has a specific, stated reason. If a feature can be built without touching your data, it is built that way.",
    },
    {
        icon: MonitorCheck,
        title: "Process on-device by default",
        body: "Four of our seven apps collect zero data. Everything happens on your device, governed by your control — not ours.",
    },
    {
        icon: Megaphone,
        title: "Disclose before we collect",
        body: "When an app sends data externally — such as an AI identification request — we say so clearly on the App Store listing before you download.",
    },
    {
        icon: CircleSlash2,
        title: "No advertising. Ever.",
        body: "Curvachip apps are not ad-supported. Your data is never sold, shared with advertisers, or used to build a profile of you.",
    },
];

const featuredPost = blogPosts.find((p) => p.featured) ?? blogPosts[0];
const otherPosts = blogPosts.filter((p) => !p.featured);
---

<Layout
    title="Privacy | Curvachip"
    description="Curvachip's approach to privacy — on-device by default, zero advertising, transparent AI disclosure, and individual privacy policies for every app."
    activeNav="privacy"
    canonicalUrl="https://curvachip.com/privacy"
    alternateMarkdown="/privacy/index.md"
>
    <!-- ══════════════════════════════════════════════════════════
       HERO
       ══════════════════════════════════════════════════════════ -->
    <Hero
        eyebrow="Our commitment"
        title="Privacy is not a feature.<br /><em>It is the foundation.</em>"
        subtitle="At Curvachip, privacy shapes every product decision before a
                single line of code is written. Here is exactly what that looks
                like in practice — no fine print, no vague reassurances."
    >
        <div
            class="hero-stat-row"
            role="list"
            aria-label="Privacy at a glance"
        >
            <div class="hero-stat" role="listitem">
                <span class="stat-number">4</span>
                <span class="stat-label">apps that collect<br />zero data</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="hero-stat" role="listitem">
                <span class="stat-number">0</span>
                <span class="stat-label">advertising<br />SDKs used</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="hero-stat" role="listitem">
                <span class="stat-number">7</span>
                <span class="stat-label">individual app<br />privacy policies</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="hero-stat" role="listitem">
                <span class="stat-number">0</span>
                <span class="stat-label">cookies on<br />this website</span>
            </div>
        </div>
    </Hero>

    <!-- ══════════════════════════════════════════════════════════
       FEATURED BLOG POST
       ══════════════════════════════════════════════════════════ -->
    <section class="section" aria-labelledby="blog-heading">
        <div class="container">
            <div class="blog-header">
                <div>
                    <p class="section-eyebrow">From the blog</p>
                    <h2 class="section-title" id="blog-heading">
                        Privacy in the real world
                    </h2>
                </div>
                {
                    otherPosts.length > 0 && (
                        <a href="/privacy/blog" class="view-all-link">
                            View all posts →
                        </a>
                    )
                }
            </div>

            <!-- Featured post — full-width card -->
            <a href={featuredPost.slug} class="featured-post-card">
                <div class="featured-post-emoji-wrap" aria-hidden="true">
                    <span class="featured-post-emoji"><featuredPost.emoji size={65}/></span
                    >
                </div>
                <div class="featured-post-body">
                    <div class="featured-post-top">
                        <span class="post-tag">{featuredPost.tag}</span>
                        <span class="post-date">{featuredPost.date}</span>
                    </div>
                    <h3 class="featured-post-title">{featuredPost.title}</h3>
                    <p class="featured-post-excerpt">{featuredPost.excerpt}</p>
                    <span class="featured-post-cta">Read the article →</span>
                </div>
            </a>

            <!-- Additional posts (only shows when you have more than one) -->
            {
                otherPosts.length > 0 && (
                    <div class="other-posts-grid">
                        {otherPosts.map((post) => (
                            <a href={post.slug} class="other-post-card">
                                <div class="other-post-top">
                                    <span class="post-tag">{post.tag}</span>
                                    <span class="post-emoji" aria-hidden="true">
                                        {post.emoji}
                                    </span>
                                </div>
                                <h3 class="other-post-title">{post.title}</h3>
                                <p class="other-post-excerpt">{post.excerpt}</p>
                                <span class="post-date">{post.date}</span>
                            </a>
                        ))}
                    </div>
                )
            }
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
       OUR PRINCIPLES
       ══════════════════════════════════════════════════════════ -->
    <section class="section section-alt" aria-labelledby="principles-heading">
        <div class="container">
            <p class="section-eyebrow">How we think</p>
            <h2 class="section-title" id="principles-heading">
                Four principles we don't compromise on
            </h2>
            <div class="principles-grid">
                {
                    principles.map((p) => (
                        <div class="principle-card">
                            <span class="principle-icon" aria-hidden="true">
                                <p.icon/>
                            </span>
                            <h3 class="principle-title">{p.title}</h3>
                            <p class="principle-body">{p.body}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
       APP-BY-APP PRIVACY SNAPSHOT
       ══════════════════════════════════════════════════════════ -->
    <section class="section" aria-labelledby="apps-heading">
        <div class="container">
            <p class="section-eyebrow">App by app</p>
            <h2 class="section-title" id="apps-heading">
                Every app, accounted for
            </h2>
            <p class="apps-intro">
                These are the same privacy labels Apple displays on every App
                Store listing. Tap any app to read its full privacy policy.
            </p>

            <div class="app-privacy-grid">
                {
                    appCards.map((app) => (
                        <a href={app.href} class="app-privacy-card">
                            <span class="app-card-emoji" aria-hidden="true">
                                <Image src={app.iconUrl} alt={app.name} width={38} height={38} />
                            </span>
                            <span class="app-card-name">{app.name}</span>
                            <span
                                class={`app-privacy-label app-privacy-label--${app.color}`}
                            >
                                {app.label}
                            </span>
                            <span class="app-card-arrow" aria-hidden="true">
                                →
                            </span>
                        </a>
                    ))
                }
            </div>

            <div class="app-privacy-legend">
                <div class="legend-item">
                    <span
                        class="legend-dot legend-dot--green"
                        aria-hidden="true"></span>
                    <span
                        ><strong>Data Not Collected</strong> — the app processes everything
                        on your device and transmits nothing.</span
                    >
                </div>
                <div class="legend-item">
                    <span class="legend-dot legend-dot--blue" aria-hidden="true"
                    ></span>
                    <span
                        ><strong>Data Not Linked to You</strong> — the app sends only
                        what you explicitly submit (e.g. a photo for AI identification).
                        It is not tied to your identity.</span
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
       WEBSITE PRIVACY
       ══════════════════════════════════════════════════════════ -->
    <section class="section section-alt" aria-labelledby="website-heading">
        <div class="container website-privacy-layout">
            <div class="website-privacy-text">
                <p class="section-eyebrow">This website</p>
                <h2 class="section-title" id="website-heading">
                    curvachip.com collects nothing
                </h2>
                <p class="website-body">
                    This is a static website. There is no server-side
                    application, no database, and no user accounts. The contact
                    form opens your own mail client — your message is never
                    routed through our servers. We use no analytics, no
                    advertising pixels, and no tracking scripts of any kind.
                </p>
                <p class="website-body">
                    The one external request this site makes is loading fonts
                    from Google Fonts. That is it. No cookies are set. No
                    consent banner is needed because there is nothing to consent
                    to.
                </p>
                <a
                    href="/privacy/website"
                    class="text-link website-policy-link"
                >
                    Read the full website privacy policy →
                </a>
            </div>
            <div
                class="website-checks"
                role="list"
                aria-label="Website privacy checklist"
            >
                {
                    [
                        ["✓", "No cookies"],
                        ["✓", "No analytics"],
                        ["✓", "No tracking pixels"],
                        ["✓", "No advertising scripts"],
                        ["✓", "No form backend"],
                        ["✓", "No user accounts"],
                        ["✓", "No data sold"],
                        ["✓", "No consent required"],
                    ].map(([mark, label]) => (
                        <div class="check-item" role="listitem">
                            <span class="check-mark" aria-hidden="true">
                                {mark}
                            </span>
                            <span>{label}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
       DEEPER RESOURCES
       ══════════════════════════════════════════════════════════ -->
    <section class="section" aria-labelledby="resources-heading">
        <div class="container">
            <p class="section-eyebrow">Go deeper</p>
            <h2 class="section-title" id="resources-heading">
                All the documents, in one place
            </h2>
            <p class="resources-intro">
                This page is an overview. Every legal detail, every data table,
                and every right you hold is documented in full below.
            </p>

            <div class="resources-grid">
                <a href="/privacy/website" class="resource-card">
                    <span class="resource-icon" aria-hidden="true"><Scroll size={24}/></span>
                    <div>
                        <h3 class="resource-title">Website Privacy Policy</h3>
                        <p class="resource-desc">
                            Exactly what curvachip.com does — and doesn't —
                            collect when you visit.
                        </p>
                        <span class="resource-link">Read policy →</span>
                    </div>
                </a>

                <a href="/privacy/terms-of-use" class="resource-card">
                    <span class="resource-icon" aria-hidden="true"><NotepadText size={24} /></span>
                    <div>
                        <h3 class="resource-title">Terms of Use</h3>
                        <p class="resource-desc">
                            The terms governing use of curvachip.com and all
                            Curvachip apps. Plain English.
                        </p>
                        <span class="resource-link">Read terms →</span>
                    </div>
                </a>

                <a href="/apps" class="resource-card">
                    <span class="resource-icon" aria-hidden="true"><MonitorSmartphone size={24}/></span>
                    <div>
                        <h3 class="resource-title">Individual App Policies</h3>
                        <p class="resource-desc">
                            Each of our seven apps has its own privacy policy.
                            Find them all on the Apps page.
                        </p>
                        <span class="resource-link">View apps →</span>
                    </div>
                </a>

                <a href="/privacy/blog/ai-chatbots" class="resource-card">
                    <span class="resource-icon" aria-hidden="true"><Bot size={24}/></span>
                    <div>
                        <h3 class="resource-title">AI Chatbot Data Risks</h3>
                        <p class="resource-desc">
                            What AI services collect, who can see it, and what
                            you should never type into one.
                        </p>
                        <span class="resource-link">Read article →</span>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
       CONTACT CTA
       ══════════════════════════════════════════════════════════ -->
    <section
        class="section section-alt priv-cta-section"
        aria-label="Privacy questions"
    >
        <div class="container priv-cta-inner">
            <span class="priv-cta-icon" aria-hidden="true"><MessageSquareLock/></span>
            <h2 class="priv-cta-title">Have a privacy question?</h2>
            <p class="priv-cta-sub">
                We read every email personally. If something on this page is
                unclear, or if you want to know something specific about how an
                app handles data, ask us directly.
            </p>
            <a href="/contact" class="btn btn-primary">Get in touch</a>
        </div>
    </section>
</Layout>

<style is:global>
    /* ── HERO ── */
    .priv-hero {
        position: relative;
        overflow: hidden;
        padding: clamp(4.5rem, 11vw, 8rem) 0 clamp(3.5rem, 8vw, 6rem);
        border-bottom: 1px solid var(--cc-border);
    }
    .priv-hero-inner {
        position: relative;
    }
    .priv-hero-title {
        font-family: var(--font-display);
        font-size: clamp(2.4rem, 6vw, 4.4rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 1.4rem;
        color: var(--cc-text);
    }
    .priv-hero-title em {
        font-style: normal;
        background: linear-gradient(135deg, var(--cc-blue), var(--cc-violet));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        padding-right: 0.05em;
        margin-right: -0.05em;
    }
    .priv-hero-sub {
        max-width: 580px;
        color: var(--cc-muted);
        font-size: 1.05rem;
        line-height: 1.75;
        margin-bottom: 3rem;
    }

    /* Stat row */
    .hero-stat-row {
        display: flex;
        align-items: center;
        gap: 0;
        flex-wrap: wrap;
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        overflow: hidden;
        width: fit-content;
        max-width: 100%;
    }
    .hero-stat {
        display: flex;
        flex-direction: column;
        padding: 1.25rem 2rem;
        align-items: center;
        text-align: center;
    }
    .stat-number {
        font-family: var(--font-display);
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: -0.04em;
        color: var(--cc-blue);
        line-height: 1;
    }
    .stat-label {
        font-size: 0.75rem;
        color: var(--cc-muted);
        margin-top: 0.35rem;
        line-height: 1.4;
    }
    .stat-divider {
        width: 1px;
        background: var(--cc-border);
        align-self: stretch;
    }
    @media (max-width: 600px) {
        .hero-stat-row {
            width: 100%;
        }
        .hero-stat {
            flex: 1;
            padding: 1rem;
        }
        .stat-number {
            font-size: 1.75rem;
        }
    }

    /* ── SHARED SECTION STYLES ── */
    .section {
        padding: clamp(3.5rem, 8vw, 6rem) 0;
    }
    .section-alt {
        background: var(--cc-surface);
    }
    .section-eyebrow {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cc-blue);
        margin-bottom: 0.5rem;
    }
    .section-title {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3.5vw, 2.2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 2rem;
        color: var(--cc-text);
    }

    /* ── BLOG ── */
    .blog-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 0;
    }
    .blog-header .section-title {
        margin-bottom: 0;
    }
    .view-all-link {
        font-size: 0.875rem;
        color: var(--cc-blue);
        transition: opacity 0.15s;
        white-space: nowrap;
        margin-bottom: 2rem;
    }
    .view-all-link:hover {
        opacity: 0.75;
        text-decoration: underline;
    }

    /* Featured post */
    .featured-post-card {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 0;
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        overflow: hidden;
        margin-top: 1.5rem;
        transition:
            border-color 0.2s,
            box-shadow 0.2s;
    }
    .featured-post-card:hover {
        border-color: rgba(91, 156, 246, 0.45);
        box-shadow: 0 0 28px rgba(91, 156, 246, 0.08);
    }
    .featured-post-emoji-wrap {
        background: linear-gradient(
            135deg,
            rgba(91, 156, 246, 0.1),
            rgba(167, 139, 250, 0.08)
        );
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid var(--cc-border);
        color: var(--cc-violet);
    }
    .featured-post-emoji {
        font-size: 3.5rem;
        line-height: 1;
    }
    .featured-post-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .featured-post-top {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .post-tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cc-blue);
        background: rgba(91, 156, 246, 0.1);
        border: 1px solid rgba(91, 156, 246, 0.2);
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
    }
    .post-date {
        font-size: 0.78rem;
        color: var(--cc-muted);
    }
    .featured-post-title {
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--cc-text);
        line-height: 1.25;
    }
    .featured-post-excerpt {
        font-size: 0.9rem;
        color: var(--cc-muted);
        line-height: 1.75;
    }
    .featured-post-cta {
        font-size: 0.875rem;
        color: var(--cc-blue);
        margin-top: auto;
    }
    .featured-post-card:hover .featured-post-cta {
        text-decoration: underline;
    }

    @media (max-width: 600px) {
        .featured-post-card {
            grid-template-columns: 1fr;
        }
        .featured-post-emoji-wrap {
            padding: 2rem;
            border-right: none;
            border-bottom: 1px solid var(--cc-border);
        }
    }

    /* Other posts */
    .other-posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.25rem;
        margin-top: 1.25rem;
    }
    .other-post-card {
        background: var(--cc-bg);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: border-color 0.2s;
    }
    .other-post-card:hover {
        border-color: rgba(91, 156, 246, 0.4);
    }
    .other-post-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .post-emoji {
        font-size: 1.25rem;
    }
    .other-post-title {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 700;
        color: var(--cc-text);
    }
    .other-post-excerpt {
        font-size: 0.85rem;
        color: var(--cc-muted);
        line-height: 1.65;
        flex: 1;
    }

    /* ── PRINCIPLES ── */
    .principles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.25rem;
    }
    .principle-card {
        background: var(--cc-bg);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 1.75rem;
        transition:
            border-color 0.2s,
            box-shadow 0.2s;
    }
    .principle-card:hover {
        border-color: rgba(91, 156, 246, 0.35);
        box-shadow: 0 0 20px rgba(91, 156, 246, 0.06);
    }
