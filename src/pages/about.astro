---
// src/pages/about.astro
// ABOUT PAGE
// ─────────────────────────────────────────────────────────────
// A deep dive on Curvachip's company values, origin story,
// mission, vision, and leadership.
// ─────────────────────────────────────────────────────────────

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Image from 'astro/components/Image.astro';
import { User, Lock, MessageSquareWarning, Plane } from "lucide-astro";

const title = "About Curvachip LLC | Mission, Values & Leadership";
const description =
    "Meet the person behind Curvachip. Learn more about our company. Our mission: build apps centered around the user. Our values: privacy, clarity, and feedback. Our vision: bring people back to what matters beyond screens.";

const values = [
    {
        icon: User,
        label: "User first, always",
        body: "Every product decision asks the same question: does this make life better for the person holding the phone? If the answer isn't clearly yes, we go back to the drawing board.",
    },
    {
        icon: Lock,
        label: "Privacy is not a feature",
        body: "Privacy is a baseline expectation. On-device processing, minimal data collection, and transparent disclosures are not selling points — they're requirements.",
    },
    {
        icon: MessageSquareWarning,
        label: "Criticism is a gift",
        body: "Negative feedback is the most valuable input we receive. We read every review, log every bug report, and treat constructive criticism as a roadmap.",
    },
    {
        icon: Plane,
        label: "Ship with intention",
        body: "No app ships without a clearly validated purpose. Ideas go through design, testing, and honest self-scrutiny before they reach the App Store.",
    },
];

const timeline = [
    {
        year: "2023",
        label: "Concept",
        body: "The idea for Curvachip begins — an indie developer and graphic designer asks: what would a software company look like if it genuinely put users first?",
    },
    {
        year: "2024",
        label: "First launch",
        body: "Curvachip LLC is formally established and the first apps arrive on the App Store, including Shadow Task and TipZap.",
    },
    {
        year: "2025",
        label: "Expansion",
        body: "The Clip family grows: StoneClip, BugClip, and PlantClip bring AI-powered identification to nature enthusiasts, students, and the curious.",
    },
    {
        year: "2026",
        label: "Today",
        body: "Curvachip continues to develop, refine, and listen — building the kind of software the developer would want on their own device.",
    },
];
---

<Layout
    title={title}
    description={description}
    activeNav="about"
    canonicalUrl="https://curvachip.com/about"
>
    <!-- ── HERO ── -->
    <Hero
        eyebrow="Curvachip LLC · Est. 2024"
        title="Privacy at the core.<br /><em>People at the center.</em>"
        subtitle="Curvachip is a one-person software company building apps for
                Apple platforms. The products are small, intentional, and built
                around a simple belief: your device should work for you, not for
                a data pipeline."
    />

    <!-- ── MISSION + VISION ── -->
    <section class="section">
        <div class="container mv-layout">
            <div class="mv-card mv-mission">
                <p class="mv-label">The mission</p>
                <h2 class="mv-title">Apps born from real needs</h2>
                <p class="mv-body">
                    Each app that Curvachip launches is built for a purpose.
                    That purpose is discovered through the people we encounter
                    every day — the frustrated dinner guest doing mental
                    arithmetic, the hiker who can't identify a plant, the
                    professional who can't stay focused.
                </p>
                <p class="mv-body">
                    A great app idea is not founded on some revolutionary
                    principle. It is founded on meeting a real need for a real
                    group of people. Every product begins as a concept, matures
                    through design and testing, and earns its place on the App
                    Store only when that need has been genuinely served.
                </p>
            </div>
            <div class="mv-card mv-vision">
                <p class="mv-label">The vision</p>
                <h2 class="mv-title">Connecting people to what matters</h2>
                <p class="mv-body">
                    Technology is humanity's greatest friend and its greatest
                    distraction. As artificial intelligence and always-on
                    connectivity pull people further into their screens,
                    something valuable gets lost.
                </p>
                <p class="mv-body">
                    Through the apps Curvachip builds, the goal is to bring
                    people back to the real world — to nature, to focused work,
                    to shared meals — in some way or another. Software should be
                    a tool that serves a moment, not a trap that consumes your
                    attention.
                </p>
            </div>
        </div>
    </section>

    <!-- ── VALUES ── -->
    <section class="section section-alt">
        <div class="container">
            <p class="eyebrow">What we stand for</p>
            <h2 class="section-title">Company values</h2>
            <div class="values-grid">
                {
                    values.map((v) => (
                        <div class="value-card">
                            <span class="value-icon" aria-hidden="true">
                                <v.icon size={20}/>
                            </span>
                            <h3 class="value-label">{v.label}</h3>
                            <p class="value-body">{v.body}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ── TIMELINE ── -->
    <section class="section">
        <div class="container">
            <p class="eyebrow">History</p>
            <h2 class="section-title">How we got here</h2>
            <ol class="timeline" aria-label="Company timeline">
                {
                    timeline.map((t) => (
                        <li class="timeline-item">
                            <div class="timeline-year-col">
                                <span class="timeline-year">{t.year}</span>
                                <div class="timeline-line" aria-hidden="true" />
                            </div>
                            <div class="timeline-content">
                                <p class="timeline-label">{t.label}</p>
                                <p class="timeline-body">{t.body}</p>
                            </div>
                        </li>
                    ))
                }
            </ol>
        </div>
    </section>

    <!-- ── LEADERSHIP ── -->
    <section class="section section-alt">
        <div class="container leadership-layout">
            <div class="leadership-text">
                <p class="eyebrow">Leadership</p>
                <h2 class="section-title">The team</h2>
                <p class="leadership-body">
                    Curvachip is led by Michael S., its founder, CEO, and sole
                    developer. Michael handles product management, design,
                    marketing, and deployment — but most importantly, he focuses
                    on the user.
                </p>
                <p class="leadership-body">
                    As a longtime software consumer, Michael understands what
                    privacy, reliability, and design mean to the people who hold
                    these apps. Every product is built to be secure, thoughtful,
                    and durable — software you can trust, from someone who holds
                    himself accountable to you.
                </p>
                <blockquote class="leadership-quote">
                    "Software is designed to make our lives easier. We take this 
                    further by designing software that is not only useful, but 
                    also delightful."
                    <footer>— Michael S., CEO</footer>
                </blockquote>
                <div class="leadership-links">
                    <a
                        href="https://www.linkedin.com/in/michael-s-21983829a"
                        target="_blank"
                        rel="noopener"
                        class="btn btn-ghost btn-sm">LinkedIn →</a
                    >
                    <a
                        href="https://github.com/Curvachip"
                        target="_blank"
                        rel="noopener"
                        class="btn btn-ghost btn-sm">GitHub →</a
                    >
                    <a href="mailto:michael@curvachip.com" class="btn btn-primary btn-sm"
                        >Get in touch</a
                    >
                </div>
            </div>
            <div class="leadership-card" aria-label="Michael S., CEO">
                <div class="leadership-avatar" aria-hidden="true">
                    <!-- <span class="avatar-initials">M</span> -->
                    <div class="avatar-initials">
                        <Image src="/michael.png" alt="Michael S." width={96} height={96} />
                    </div>
                    <div class="avatar-ring" aria-hidden="true"></div>
                </div>
                <p class="leadership-name">Michael S.</p>
                <p class="leadership-role">CEO · Indie Developer · Designer</p>
                <p class="leadership-location">Curvachip LLC · Est. 2024</p>
                <div class="leadership-tags">
                    <span class="tag">SwiftUI</span>
                    <span class="tag">iOS</span>
                    <span class="tag">macOS</span>
                    <span class="tag">UX Design</span>
                    <span class="tag">Product</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PRIVACY COMMITMENT ── -->
    <section class="section">
        <div class="container">
            <div class="privacy-commitment">
                <div class="pc-icon" aria-hidden="true"><Lock/></div>
                <h2 class="pc-title">Our privacy commitment</h2>
                <p class="pc-body">
                    None of our apps collect data unless strictly necessary. We
                    believe that the violation of your privacy is a direct
                    infringement upon the trust you place in us. We take extra
                    care to protect your data and process it on-device whenever
                    possible.
                </p>
                <p class="pc-body">
                    When an app requires external data processing — such as an
                    AI request — this will always be disclosed clearly on the
                    App Store listing and in the accompanying privacy policy. No
                    surprises. No fine print you have to go looking for.
                </p>
                <div class="pc-actions">
                    <a href="/privacy" class="btn btn-primary"
                        >Read our privacy post</a
                    >
                    <a href="/apps" class="btn btn-ghost"
                        >See app privacy policies</a
                    >
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>

    .section {
        padding: clamp(6rem, 12vw, 9rem) 0;
    }
    .section-alt {
        background: var(--cc-surface);
    }
    .section-title {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: clamp(1.5rem, 3.5vw, 2.2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 2.5rem;
    }

    /* Mission + Vision */
    .mv-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    @media (max-width: 700px) {
        .mv-layout {
            grid-template-columns: 1fr;
        }
    }
    .mv-card {
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 2.25rem;
    }
    .mv-mission {
        border-top: 3px solid var(--cc-blue);
    }
    .mv-vision {
        border-top: 3px solid var(--cc-violet);
    }
    .mv-label {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cc-muted);
        margin-bottom: 0.6rem;
    }
    .mv-title {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: -0.015em;
        margin-bottom: 1.1rem;
    }
    .mv-body {
        font-size: 0.9rem;
        color: var(--cc-muted);
        line-height: 1.8;
        margin-bottom: 0.75rem;
    }

    /* Values */
    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.25rem;
    }
    .value-card {
        background: var(--cc-bg);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 2rem 1.75rem;
        transition:
            border-color 0.2s,
            box-shadow 0.2s;
    }
    .value-card:hover {
        border-color: rgba(91, 156, 246, 0.4);
        box-shadow: 0 0 24px rgba(91, 156, 246, 0.07);
    }
    .value-icon {
        display: block;
        font-size: 1.4rem;
        color: var(--cc-blue);
        margin-bottom: 1rem;
    }
    .value-label {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 0.6rem;
    }
    .value-body {
        color: var(--cc-muted);
        font-size: 0.875rem;
        line-height: 1.7;
    }

    /* Timeline */
    .timeline {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .timeline-item {
        display: grid;
        grid-template-columns: 100px 1fr;
        gap: 1.5rem;
        padding-bottom: 2.5rem;
    }
    .timeline-year-col {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        padding-top: 0.1rem;
    }
    .timeline-year {
        font-family: "SFMono-Regular", "SF Mono", "JetBrains Mono", monospace;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--cc-blue);
        background: rgba(91, 156, 246, 0.1);
        border: 1px solid rgba(91, 156, 246, 0.2);
        padding: 0.2rem 0.55rem;
        border-radius: 4px;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }
    .timeline-line {
        width: 1px;
        flex: 1;
        background: var(--cc-border);
        margin-top: 0.75rem;
        margin-right: calc(50% - 0.5px);
    }
    .timeline-item:last-child .timeline-line {
        display: none;
    }
    .timeline-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cc-muted);
        margin-bottom: 0.4rem;
    }
    .timeline-body {
        font-size: 0.9rem;
        color: var(--cc-muted);
        line-height: 1.75;
    }

    /* Leadership */
    .leadership-layout {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 4rem;
        align-items: start;
    }
    @media (max-width: 768px) {
        .leadership-layout {
            grid-template-columns: 1fr;
        }
    }
    .leadership-body {
        font-size: 0.95rem;
        color: var(--cc-muted);
        line-height: 1.8;
        margin-bottom: 1rem;
    }
    .leadership-quote {
        border-left: 3px solid var(--cc-violet);
        padding-left: 1.25rem;
        font-family: var(--font-display);
        font-style: italic;
        font-size: 1rem;
        color: var(--cc-text);
        line-height: 1.75;
        margin: 2rem 0;
    }
    .leadership-quote footer {
        font-style: normal;
        font-size: 0.8rem;
        color: var(--cc-muted);
        margin-top: 0.5rem;
        font-family: var(--font-body);
    }
    .leadership-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .leadership-card {
        background: var(--cc-surface);
        border: 1px solid var(--cc-border);
        border-radius: var(--cc-radius);
        padding: 2rem 1.75rem;
        text-align: center;
        min-width: 220px;
    }
    .leadership-avatar {
        position: relative;
        width: 80px;
        height: 80px;
        margin-inline: auto;
        margin-bottom: 1.25rem;
    }
    .avatar-initials {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        clip-path: circle();
        /* background: linear-gradient(135deg, var(--cc-blue), var(--cc-violet));
        border-radius: 50%;
        font-size: 2rem;
        font-weight: 700;
        color: #07070f;
        font-family:
            system-ui,
            -apple-system,
            sans-serif; */
        position: relative;
        z-index: 1;
    }
    .avatar-ring {
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 1px solid rgba(91, 156, 246, 0.3);
        animation: pulse-ring 3s ease-in-out infinite;
    }
    @keyframes pulse-ring {
        0%,
        100% {
            opacity: 0.4;
            transform: scale(1);
        }
        50% {
            opacity: 1;
            transform: scale(1.04);
        }
    }
    .leadership-name {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.3rem;
    }
    .leadership-role {
        font-size: 0.8rem;
        color: var(--cc-blue);
        margin-bottom: 0.25rem;
    }
    .leadership-location {
        font-size: 0.78rem;
        color: var(--cc-muted);
        margin-bottom: 1.25rem;
    }
    .leadership-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        justify-content: center;
    }
    .tag {
        font-size: 0.72rem;
        font-weight: 500;
        background: var(--cc-bg);
        border: 1px solid var(--cc-border);
        border-radius: 4px;
        padding: 0.2rem 0.55rem;
        color: var(--cc-muted);
    }

    /* Privacy commitment */
    .privacy-commitment {
        max-width: 680px;
    }
    .pc-icon {
        font-size: 2rem;
        color: var(--cc-blue);
        margin-bottom: 1.25rem;
    }
    .pc-title {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 1.25rem;
    }
    .pc-body {
        font-size: 0.95rem;
        color: var(--cc-muted);
        line-height: 1.8;
        margin-bottom: 1rem;
    }
    .pc-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 2rem;
    }
</style>
